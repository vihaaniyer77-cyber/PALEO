import os
import numpy as np
import pandas as pd
import lightkurve as lk

def stitch_kepler_longcadence(target, flux_column="pdcsap_flux"):
    sr = lk.search_lightcurve(target, mission="Kepler", cadence="long")
    lcc = sr.download_all(flux_column=flux_column)

    lcs = [lc for lc in (lcc or []) if lc is not None and len(lc.time) > 0]
    if len(lcs) == 0:
        raise RuntimeError(f"No Kepler long-cadence LCs found for {target}.")

    lc = lk.LightCurveCollection(lcs).stitch()
    lc = lc.remove_nans().normalize()

    tmp = lc.sort()
    if tmp is not None:
        lc = tmp

    # Remove duplicate timestamps
    t = lc.time.value
    _, keep_idx = np.unique(t, return_index=True)
    keep_idx = np.sort(keep_idx)
    lc = lc[keep_idx]

    return lc

# -----------------------------
# CONFIG
# -----------------------------
STAR_CSV = "keplerstellar_with_kepler_hostnames_ONLY.csv"
CACHE_DIR = "lightcurves_cache_fits"
FLUX_COLUMN = "pdcsap_flux"

os.makedirs(CACHE_DIR, exist_ok=True)

df = pd.read_csv(STAR_CSV, on_bad_lines="skip")

manifest_rows = []

for _, row in df.iterrows():
    kepid = int(row["kepid"])
    name  = str(row["hostname"])
    target = f"KIC {kepid}"

    outpath = os.path.join(CACHE_DIR, f"kic_{kepid}_lc.fits")

    # Skip if already cached
    if os.path.exists(outpath) and os.path.getsize(outpath) > 0:
        manifest_rows.append({
            "kepid": kepid, "hostname": name, "filepath": outpath,
            "status": "cached", "n_points": np.nan, "t_min": np.nan, "t_max": np.nan
        })
        continue

    try:
        lc = stitch_kepler_longcadence(target, flux_column=FLUX_COLUMN)

        # Save to FITS
        lc.to_fits(outpath, overwrite=True)

        tvals = lc.time.value
        manifest_rows.append({
            "kepid": kepid,
            "hostname": name,
            "filepath": outpath,
            "status": "ok",
            "n_points": int(len(lc.time)),
            "t_min": float(np.nanmin(tvals)),
            "t_max": float(np.nanmax(tvals)),
        })

        print(f"[OK] {name} (KIC {kepid}) -> {outpath}  (N={len(lc.time)})")

    except Exception as e:
        manifest_rows.append({
            "kepid": kepid, "hostname": name, "filepath": outpath,
            "status": f"fail: {type(e).__name__}", "n_points": np.nan, "t_min": np.nan, "t_max": np.nan
        })
        print(f"[SKIP] {name} (KIC {kepid}) failed: {e}")

# Write manifest
manifest = pd.DataFrame(manifest_rows)
manifest.to_csv(os.path.join(CACHE_DIR, "manifest.csv"), index=False)
print(f"\nWrote manifest -> {os.path.join(CACHE_DIR, 'manifest.csv')}")



