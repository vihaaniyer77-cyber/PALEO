import os, zipfile
from google.colab import files

CACHE_DIR = "lightcurves_cache_fits"
ZIP_PATH = f"{CACHE_DIR}.zip"

# Safety: remove existing zip so you don't zip an old one by accident
if os.path.exists(ZIP_PATH):
    os.remove(ZIP_PATH)

# Zip entire folder with stable, clean relative paths
with zipfile.ZipFile(ZIP_PATH, "w", compression=zipfile.ZIP_DEFLATED) as z:
    for root, _, filenames in os.walk(CACHE_DIR):
        for fn in filenames:
            full = os.path.join(root, fn)

            # Avoid zipping the zip file if it's inside the folder (rare but safe)
            if os.path.abspath(full) == os.path.abspath(ZIP_PATH):
                continue

            # Store paths relative to CACHE_DIR so zip always contains:
            # lightcurves_cache_fits/<files...>
            arcname = os.path.relpath(full, start=os.path.dirname(CACHE_DIR) or ".")
            # If you want *no* top folder, use: start=CACHE_DIR
            # arcname = os.path.relpath(full, start=CACHE_DIR)

            z.write(full, arcname=arcname)

print("Wrote:", ZIP_PATH)
files.download(ZIP_PATH)

