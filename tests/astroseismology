# ============================================================
# PALEO — ASTEROSEISMOLOGY COMPATIBILITY DEMO
# ============================================================
# Demonstrates that PALEO's detrending:
#   1. PRESERVES red giant solar-like oscillations (nu_max ~10-150 uHz)
#   2. DETECTS embedded planet transits even in oscillating stars
#   3. Allows asteroseismic characterization from post-detrend residuals
#
# Colab-ready — requires: batman, scipy, numpy, matplotlib
# ============================================================

import numpy as np
import matplotlib.pyplot as plt
import matplotlib.gridspec as gridspec
from scipy.ndimage import median_filter
from scipy.signal import find_peaks
from astropy.timeseries import LombScargle
from astropy.convolution import Box1DKernel, convolve
import batman
import warnings
warnings.simplefilter("ignore")

np.random.seed(7)

# ==============================================================
# CONFIG
# ==============================================================
CADENCE       = 0.021        # days (~30 min, TESS 2-min binned to 30)
DURATION_DAYS = 27.0
NOISE_PPM     = 100          # photon noise floor
DETREND_WIN   = 241          # rolling-median window (5-day window)

# Asteroseismic parameters for a typical oscillating red giant
# (solar-like oscillations; freq in uHz)
NU_MAX_UHZ    = 30.0         # frequency of maximum power (uHz) — safely below pulsator gate
DELTA_NU_UHZ  =  5.0         # large frequency separation (uHz) — scales as mean density
N_MODES       = 12           # number of radial modes to include
OSC_AMP_PPM   = 300          # oscillation amplitude (ppm)
MODE_WIDTH_UHZ = 1.2         # mode lifetime → Lorentzian width

# Planet parameters
RP_RSTAR      = 0.09         # radius ratio (~Jupiter around a giant)
TRANSIT_DUR   = 0.22         # days
T0_PLANET     = 11.3         # transit centre (days from start)

N_PLOT_SYSTEMS = 5           # how many red giant systems to simulate

# Unit conversion
UHZ_TO_CPD    = 86400 / 1e6  # 1 uHz = 0.0864 cycles/day


# ==============================================================
# 1. SIMULATION
# ==============================================================

def simulate_oscillations(time, nu_max, delta_nu, n_modes,
                           amplitude_ppm, mode_width):
    """
    Simulate solar-like oscillations as a sum of stochastically
    excited, exponentially damped sinusoids around nu_max.

    Each radial mode is a Lorentzian in frequency space, realised
    as a damped sinusoid with random phase and amplitude scatter.
    """
    flux_osc = np.zeros_like(time)
    rng = np.random

    # Radial modes centred on nu_max with spacing delta_nu
    for n in range(-n_modes // 2, n_modes // 2 + 1):
        nu_n = nu_max + n * delta_nu        # uHz
        nu_n_cpd = nu_n * UHZ_TO_CPD       # cycles/day

        # Gaussian envelope in power (Gaussian approximation to the PS envelope)
        env = np.exp(-0.5 * ((nu_n - nu_max) / (3 * delta_nu)) ** 2)

        # Random amplitude + phase
        amp   = amplitude_ppm * 1e-6 * env * rng.rayleigh(1.0)
        phase = rng.uniform(0, 2 * np.pi)

        # Damping timescale ~ 1 / (pi * mode_width)
        tau_days = 1.0 / (np.pi * mode_width * UHZ_TO_CPD)
        damp = np.exp(-np.abs(time - time.mean()) / tau_days)

        flux_osc += amp * damp * np.cos(2 * np.pi * nu_n_cpd * time + phase)

    return flux_osc


def simulate_red_giant(t0_planet=None, include_planet=True):
    time = np.arange(0, DURATION_DAYS, CADENCE)
    flux = np.ones_like(time)

    # Slow stellar rotation (background)
    rot_amp = np.random.uniform(0.001, 0.005)
    rot_per = np.random.uniform(30, 120)    # days (slow red giant rotation)
    flux += rot_amp * np.sin(2 * np.pi * time / rot_per)

    # Solar-like oscillations
    nu_max   = NU_MAX_UHZ   * np.random.uniform(0.7, 1.4)
    delta_nu = DELTA_NU_UHZ * np.random.uniform(0.8, 1.2)
    osc = simulate_oscillations(time, nu_max, delta_nu, N_MODES,
                                 OSC_AMP_PPM, MODE_WIDTH_UHZ)
    flux += osc

    # Planet transit
    if include_planet and t0_planet is not None:
        p = batman.TransitParams()
        p.t0 = t0_planet;  p.per = 10000.0;  p.rp = RP_RSTAR
        p.a  = max(2.0, 10000.0 / (np.pi * TRANSIT_DUR))
        p.inc = 90.0;  p.ecc = 0.0;  p.w = 90.0
        p.u  = [0.3, 0.3];  p.limb_dark = "quadratic"
        try:
            flux *= batman.TransitModel(p, time).light_curve(p)
        except Exception:
            pass

    # Photon noise
    flux += np.random.normal(0, NOISE_PPM * 1e-6, len(time))

    return time, flux, nu_max, delta_nu


def detrend(flux, window=DETREND_WIN):
    trend = median_filter(flux, size=window, mode="nearest")
    return flux / np.clip(trend, 1e-8, None)


# ==============================================================
# 2. POWER SPECTRUM HELPERS
# ==============================================================

def power_spectrum(time, flux):
    """GLS power spectrum in uHz."""
    dt_days  = CADENCE
    freq_max = 0.5 / dt_days           # Nyquist in cpd
    freq_uHz = np.linspace(1, freq_max / UHZ_TO_CPD, 5000)
    freq_cpd = freq_uHz * UHZ_TO_CPD

    ls   = LombScargle(time, flux - np.median(flux), normalization="psd")
    psd  = ls.power(freq_cpd)          # power in psd normalisation
    psd_ppm2 = psd * (1e6) ** 2        # convert to ppm^2/uHz
    return freq_uHz, psd_ppm2


def smooth_ps(psd, width_bins=15):
    """Box-car smooth for background power spectrum."""
    kernel = Box1DKernel(width_bins)
    return convolve(psd, kernel, boundary="extend")


def estimate_nu_max(freq_uHz, psd_raw):
    """
    Background-corrected nu_max estimator (standard asteroseismic approach).

    1. Estimate background: very wide (2000-bin) boxcar smooth of the PSD.
       This traces the red-noise slope from slow rotation without being
       sensitive to the oscillation peaks.
    2. Divide PSD by background -> flat SNR spectrum with oscillation excess.
    3. Find peak of 100-bin smooth of SNR (picks out the Gaussian excess).
    Only search above 10 uHz to avoid trend residuals.
    """
    background = smooth_ps(psd_raw, width_bins=2000)
    snr        = psd_raw / np.maximum(background, 1e-30)
    snr_smooth = smooth_ps(snr, width_bins=100)
    search_mask = freq_uHz > 10.0
    if search_mask.sum() == 0:
        return freq_uHz[np.argmax(snr_smooth)]
    i_max = np.argmax(snr_smooth[search_mask])
    return freq_uHz[search_mask][i_max]



