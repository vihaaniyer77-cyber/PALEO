retained_list = []

for i in range(N_PLOT_SYSTEMS):
    t0_p = np.random.uniform(5, 22)
    time_i, flux_i, nu_max_i, dnu_i = simulate_red_giant(
        t0_planet=t0_p, include_planet=True)
    flux_det_i = detrend(flux_i)

    # Power in the oscillation band before and after detrend
    freq_i,  psd_raw_i = power_spectrum(time_i, flux_i)
    freq_i,  psd_det_i = power_spectrum(time_i, flux_det_i)

    band = (freq_i >= 0.6 * nu_max_i) & (freq_i <= 1.4 * nu_max_i)
    psd_raw_sm_i = smooth_ps(psd_raw_i, 15)
    psd_det_sm_i = smooth_ps(psd_det_i, 15)

    peak_raw = np.max(psd_raw_sm_i[band]) if band.sum() > 0 else 0
    peak_det = np.max(psd_det_sm_i[band]) if band.sum() > 0 else 0
    retained = 100 * peak_det / peak_raw if peak_raw > 0 else 0
    retained_list.append(retained)

    # Pulsator gate (checks raw flux at 4-48 cpd)
    ls_i    = LombScargle(time_i, flux_i - np.median(flux_i),
                          normalization="model")
    fc_i    = freq_i * UHZ_TO_CPD
    pb_i    = (fc_i >= 4.0) & (fc_i <= 48.0)
    puls_pw = np.max(ls_i.power(fc_i[pb_i])) if pb_i.sum() > 0 else 0
    gate_str = "REJECTED" if puls_pw > 1.0 else "passed"

    # Transit detection
    zoom_i = np.abs(time_i - t0_p) < 0.5
    depth_i = (np.median(flux_det_i)
               - np.min(flux_det_i[zoom_i])) if zoom_i.sum() > 0 else 0
    transit_found = depth_i > 3 * NOISE_PPM * 1e-6

    print(f"  {i+1:>2}  {nu_max_i:>11.1f}  {peak_raw:>9.0f}  "
          f"{peak_det:>9.0f}  {retained:>8.1f}%  {gate_str:>10}  "
          f"{'YES' if transit_found else 'no':>8}")

