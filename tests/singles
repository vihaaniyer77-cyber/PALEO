DEVICE = torch.device("cuda" if torch.cuda.is_available() else "cpu")

# ==========================================
# 1. TCN MODEL DEFINITIONS
# ==========================================
class Chomp1d(nn.Module):
    def __init__(self, chomp_size):
        super().__init__()
        self.chomp_size = int(chomp_size)
    def forward(self, x):
        return x[:, :, :-self.chomp_size] if self.chomp_size > 0 else x

class ResidualTCNBlock(nn.Module):
    def __init__(self, in_ch, out_ch, kernel_size, dilation, dropout=0.15, groups_gn=None):
        super().__init__()
        padding = (kernel_size - 1) * dilation
        self.conv1 = nn.Conv1d(in_ch, out_ch, kernel_size, padding=padding, dilation=dilation)
        self.chomp1 = Chomp1d(padding)
        if groups_gn is not None and groups_gn > 0:
            self.n1 = nn.GroupNorm(num_groups=max(1, min(groups_gn, out_ch)), num_channels=out_ch)
        else:
            self.n1 = nn.BatchNorm1d(out_ch)
        self.relu1 = nn.ReLU()
        self.drop1 = nn.Dropout(dropout)

        self.conv2 = nn.Conv1d(out_ch, out_ch, kernel_size, padding=padding, dilation=dilation)
        self.chomp2 = Chomp1d(padding)
        if groups_gn is not None and groups_gn > 0:
            self.n2 = nn.GroupNorm(num_groups=max(1, min(groups_gn, out_ch)), num_channels=out_ch)
        else:
            self.n2 = nn.BatchNorm1d(out_ch)
        self.relu2 = nn.ReLU()
        self.drop2 = nn.Dropout(dropout)

        self.downsample = nn.Conv1d(in_ch, out_ch, 1) if in_ch != out_ch else None
        self.relu = nn.ReLU()

    def forward(self, x):
        out = self.drop1(self.relu1(self.n1(self.chomp1(self.conv1(x)))))
        out = self.drop2(self.relu2(self.n2(self.chomp2(self.conv2(out)))))
        res = x if self.downsample is None else self.downsample(x)
        return self.relu(out + res)

class TCNEventDetector(nn.Module):
    def __init__(self, in_ch=1, hidden=128, depth=8, kernel_size=5, dropout=0.15, groups_gn=None, out_ch=2):
        super().__init__()
        dilations = [2**i for i in range(depth)]
        blocks = []
        c_in = in_ch
        for d in dilations:
            blocks.append(ResidualTCNBlock(c_in, hidden, kernel_size, d, dropout, groups_gn))
            c_in = hidden
        self.backbone = nn.Sequential(*blocks)
        self.head = nn.Conv1d(hidden, out_ch, 1)

    def forward(self, x):
        return self.head(self.backbone(x))

def load_model(path):
    if not os.path.exists(path):
        print(f"[ERROR] Model file '{path}' not found!")
        return None

    ckpt = torch.load(path, map_location=DEVICE)
    state_dict = ckpt["model_state"] if "model_state" in ckpt else ckpt
    config = ckpt.get("config", {})

    hidden = config.get("hidden", 128)
    depth = config.get("depth", 8)
    kernel = config.get("kernel_size", 5)
    dropout = config.get("dropout", 0.15)
    gn = config.get("groups_gn", 8)
    if any("bn1.weight" in k for k in state_dict.keys()): gn = None

    model = TCNEventDetector(in_ch=1, hidden=hidden, depth=depth, kernel_size=kernel, dropout=dropout, groups_gn=gn).to(DEVICE)
    new_state_dict = {}
    for k, v in state_dict.items():
        new_k = k
        if "bn1" in k: new_k = k.replace("bn1", "n1")
        elif "gn1" in k: new_k = k.replace("gn1", "n1")
        elif "bn2" in k: new_k = k.replace("bn2", "n2")
        elif "gn2" in k: new_k = k.replace("gn2", "n2")
        new_state_dict[new_k] = v

    model.load_state_dict(new_state_dict, strict=False)
    model.eval()
    return model


# ==========================================
# 2. PHYSICS-AWARE VALIDATOR (BATMAN)
# ==========================================
class GuidedValidator:
    def validate_candidate(self, time, flux, t_peak_tcn, window_width=0.5):
        mask = np.abs(time - t_peak_tcn) < (window_width / 2.0)
        t_local = time[mask]
        f_local = flux[mask]

        if len(t_local) < 5:
            return {"verdict": "REJECTED", "gain": 0.0, "params": {}}

        # ROBUST BASELINE: Exclude the bottom 20% of points (the transit itself)
        # from skewing the median downwards. This makes the `chi2_flat` (error of a flat line)
        # much worse, allowing the transit model to easily achieve a higher "Gain".
        f_sorted = np.sort(f_local)
        robust_median = np.median(f_sorted[int(len(f_sorted)*0.2):]) if len(f_sorted) > 5 else np.median(f_local)

        chi2_flat = np.sum((f_local - robust_median)**2)
        if chi2_flat == 0: chi2_flat = 1e-10

        def transit_model(params, t):
            t0, rp, dur = params
            m_params = batman.TransitParams()
            m_params.t0 = t0
            m_params.per = 10000.0
            m_params.rp = rp
            m_params.a = 10000.0 / (np.pi * dur)
            m_params.inc = 90.0
            m_params.ecc = 0.0
            m_params.w = 90.0
            m_params.u = [0.3, 0.3]
            m_params.limb_dark = "quadratic"
            m = batman.TransitModel(m_params, t)
            return m.light_curve(m_params) * robust_median

        def objective(params):
            return np.sum((f_local - transit_model(params, t_local))**2)

        # WIDER BOUNDS: Allow the optimizer to find shallower/wider fits if noise is heavy
        bounds = [(t_peak_tcn - 0.2, t_peak_tcn + 0.2), (0.001, 0.8), (0.01, 1.0)]
        guesses = [t_peak_tcn, 0.05, 0.1]

        try:
            res = minimize(objective, guesses, bounds=bounds, method='L-BFGS-B')
            chi2_transit = res.fun
            best = res.x
        except Exception as e:
            return {"verdict": "ERROR", "gain": 0.0, "params": {}, "error": str(e)}

        gain = 1.0 - (chi2_transit / chi2_flat)
        # LOWER THRESHOLD: A gain of >0.1% over a flat line is enough to "Validate" a TCN flag
        verdict = "VALIDATED" if gain > 0.001 else "REJECTED"

        return {
            "verdict": verdict, "gain": gain,
            "params": {"t0": best[0], "rp": best[1], "dur": best[2]}
        }


# ==========================================
# 3. NOISE GENERATORS
# ==========================================
def inject_rotational_modulation(time, flux, amp=0.01, period=2.0):
    """ Starspots simulating rotational modulation via low frequency sine waves. """
    phase = np.random.uniform(0, 2 * np.pi)
    modulation = 1.0 + amp * np.sin(2 * np.pi * time / period + phase)
    # To keep relative depths equivalent, we multiply the flux by the modulation
    return flux * modulation

def inject_flares(time, flux, max_flares=3, max_amp=0.03):
    """ Adds Fast-Rise Exponential-Decay (FRED) signals simulating flares. """
    n_flares = np.random.randint(1, max_flares + 1)
    flare_profile = np.zeros_like(time)

    for _ in range(n_flares):
        # Pick random peak
        t_peak = np.random.uniform(time[0] + 0.5, time[-1] - 0.5)
        amp = np.random.uniform(0.005, max_amp)
        decay_tau = np.random.uniform(0.05, 0.15) # decay timescale
        rise_tau = decay_tau / 10.0 # very fast rise

        flare_term = np.zeros_like(time)
        rise_mask = (time <= t_peak) & (time > t_peak - 0.5)
        decay_mask = (time > t_peak)

        # Exponential rise
        flare_term[rise_mask] = amp * np.exp((time[rise_mask] - t_peak) / rise_tau)
        # FRED decay
        flare_term[decay_mask] = amp * np.exp(-(time[decay_mask] - t_peak) / decay_tau)

        flare_profile += flare_term

    return flux + flare_profile

def generate_synthetic_lc(rp, noise_type="none", t0=2.5, duration=0.1, cadence=29.4244, window_days=5.0):
    """ Generates a single TESS window with a batman transit and optional noise models. """
    dt_days = cadence / (60.0 * 24.0)
    T = int(np.floor(window_days / dt_days))
    time = np.arange(0, T) * dt_days

    params = batman.TransitParams()
    params.t0 = t0
    params.per = 10000.0
    params.rp = rp
    params.a = 10000.0 / (np.pi * duration)
    params.inc = 90.0
    params.ecc = 0.0
    params.w = 90.0
    params.u = [0.3, 0.3]
    params.limb_dark = "quadratic"

    m = batman.TransitModel(params, time)
    flux = m.light_curve(params)

    # Inject Noise Profiles
    if noise_type == "rotational":
        flux = inject_rotational_modulation(time, flux)
    elif noise_type == "flares":
        flux = inject_flares(time, flux)
    elif noise_type == "combined":
        flux = inject_rotational_modulation(time, flux)
        flux = inject_flares(time, flux)

    return time, flux


# ==========================================
# 4. SCIENCE FAIR MAIN PIPELINE
# ==========================================
def run_science_fair_pipeline():
    model_path = "tcn_epoch_020.pt"
    model = load_model(model_path)
    if model is None: return

    validator = GuidedValidator()

    # 5 Planet Types
    rp_values = [0.10, 0.08, 0.06, 0.04, 0.01]

    # 4 Noise Regimes
    noise_regimes = ["none", "rotational", "flares", "combined"]

    # Run config
    N_RUNS = 100

    print(f"===========================================================")
    print(f"PALEO SYNTHETIC TESTING SUITE")
    print(f"Configurations: {len(rp_values)} Radii x {len(noise_regimes)} Noise Profiles = {len(rp_values) * len(noise_regimes)} Tests")
    print(f"Runs per Config: {N_RUNS}")
    print(f"Total Iterations: {len(rp_values) * len(noise_regimes) * N_RUNS}")
    print(f"===========================================================\n")

    results = []

    # Progress Bar loop
    total_iters = len(rp_values) * len(noise_regimes)
    pbar = tqdm(total=total_iters, desc="Testing Matrix")

    for rp in rp_values:
        for noise in noise_regimes:
            recoveries = 0

            for _ in range(N_RUNS):
                # Randomize transit center slightly
                t0_true = np.random.uniform(2.0, 3.0)

                time_ax, flux = generate_synthetic_lc(rp, noise_type=noise, t0=t0_true)

                # --- PREPROCESSING BOOST ---
                # 1. Detrend: Remove low-frequency rotational modulation using a moving median filter
                # We use a window size of ~ 15 hours, since typical transits are < 5 hrs.
                # (15 hours / 30 mins) = 30 points
                flux_series = pd.Series(flux)
                baseline = flux_series.rolling(window=31, center=True, min_periods=5).median()
                baseline = baseline.bfill().ffill()

                # Divisive detrending
                detrended_flux = (flux / baseline).values

                # 2. Iterative Outlier Clipping (Flattens extreme flares to help TCN focus on dips)
                std_flux = np.std(detrended_flux)
                # Clip anything higher than 3 sigma (transits are negative, flares are positive)
                detrended_flux = np.clip(detrended_flux, a_min=None, a_max=1.0 + 3 * std_flux)

                # Preprocess for TCN (x/median - 1.0)
                x_norm = detrended_flux - 1.0
                # ---------------------------

                x_tensor = torch.from_numpy(x_norm).float().unsqueeze(0).unsqueeze(0).to(DEVICE)

                with torch.no_grad():
                    logits = model(x_tensor)
                    probs = torch.sigmoid(logits[:, 0, :])

                p_curve = probs.cpu().numpy()[0]
                # LOWER TCN THRESHOLD: Catch more faint signals
                peaks, _ = find_peaks(p_curve, height=0.05, distance=20)

                recovered = False

                # Check peaks
                if len(peaks) > 0:
                    peaks = sorted(peaks, key=lambda idx: p_curve[idx], reverse=True)

                    # See if any of the top peaks match the truth
                    for peak_idx in peaks[:3]: # Check top 3 highest confidence peaks
                        t_peak = time_ax[peak_idx]

                        # Validate temporal closeness (must be within ~0.2 days of true transit)
                        if abs(t_peak - t0_true) < 0.2:
                            # Pass the ORIGINAL flux to the physics validator (it handles its own local median)
                            val_res = validator.validate_candidate(time_ax, flux, t_peak)

                            # Validated purely on morphological gain match
                            if val_res['verdict'] == "VALIDATED":
                                recovered = True
                                break

                if recovered:
                    recoveries += 1

            acc = recoveries / N_RUNS
            results.append({
                "Rp": rp,
                "Noise": noise,
                "Recall_Percent": acc * 100.0,
                "Recovered": recoveries,
                "Missed": N_RUNS - recoveries
            })
            pbar.update(1)

    pbar.close()

    # Construct DF and Plot
    df = pd.DataFrame(results)
    print("\nFINAL PIPELINE STATISTICS:")
    print("=====================================================")
    print(df.to_string(index=False))
    print("=====================================================")

    # Create Grouped Bar Chart
    plt.figure(figsize=(12, 7))

    x = np.arange(len(rp_values))
    width = 0.2

    # Specific colors for presentation pop
    colors = {
        "none": "#2ecc71",       # Green
        "rotational": "#3498db", # Blue
        "flares": "#e67e22",     # Orange
        "combined": "#e74c3c"    # Red
    }

    for i, noise in enumerate(noise_regimes):
        subset = df[df["Noise"] == noise]
        # Offset bars based on width
        offsets = x + (i - 1.5) * width
        plt.bar(offsets, subset["Recall_Percent"], width, label=noise.title(), color=colors[noise], edgecolor='black')

    plt.title('PALEO TCN Pipeline - Recovery Recall under Synthetic Noise Regimes', fontsize=16)
    plt.ylabel('Recall Accuracy (%)', fontsize=14)
    plt.xlabel('Planetary Radius (Rp/R*)', fontsize=14)
    plt.xticks(x, [f"{rp:.2f}" for rp in rp_values], fontsize=12)
    plt.ylim(0, 105)

    # Overlay raw data labels on bars
    for i, noise in enumerate(noise_regimes):
        subset = df[df["Noise"] == noise]
        offsets = x + (i - 1.5) * width
        for offset, val in zip(offsets, subset["Recall_Percent"]):
            plt.text(offset, val + 1.5, f"{int(val)}%", ha='center', va='bottom', fontsize=9, rotation=0)

    plt.legend(title='Noise Injection Layer', fontsize=12, title_fontsize=12, loc='lower right')
    plt.grid(axis='y', linestyle='--', alpha=0.7)

    plt.tight_layout()
    plt.show()

# Run it
if __name__ == "__main__":
    run_science_fair_pipeline()
