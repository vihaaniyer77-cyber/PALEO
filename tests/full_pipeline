# 5. EVALUATION PIPELINE
# ==============================================================
def evaluate_pipeline(dataset, model):
    validator = FoldedValidator()
    tp, fp, fn, tn = 0, 0, 0, 0
    fn_reasons = {"tcn_missed": 0, "validator_rejected": 0, "eb_filter_false_alarm": 0, "bls_missed": 0, "pulsator_check": 0}
    fp_reasons = {"was_eb": 0, "was_pulsator": 0, "was_modulation": 0, "was_noise": 0}
    planet_types = ["HotJupiter", "Saturn", "Neptune", "SuperEarth"]
    per_type = {t: {"tp": 0, "fn": 0} for t in planet_types}

    BATCH_SIZE = 128

    for i in tqdm(range(0, len(dataset), BATCH_SIZE), desc="Evaluating Streamlined Pipeline"):
        batch = dataset[i:i+BATCH_SIZE]
        fluxes = [b["flux"] for b in batch]
        x_tensor = torch.tensor(np.array(fluxes), dtype=torch.float32, device=DEVICE).unsqueeze(1) - 1.0

        with torch.no_grad():
            logits = model(x_tensor)
            probs = torch.sigmoid(logits[:, 0, :]).cpu().numpy()

        for b_idx, item in enumerate(batch):
            time_ax = item["time"]
            flux = item["flux"]
            truth = item["true_label"]
            # Detrend: remove slow stellar modulation before BLS
            # (window=31pts ~15hr >> transit duration 0.04-0.2d)
            flux_detrended = detrend_flux(flux)

            pipeline_claims_planet = False
            rejection_stage = ""

            is_puls = is_pulsator(time_ax, flux)
            if is_puls:
                rejection_stage = "pulsator_check"
            else:
                p_curve = probs[b_idx][:len(flux)]

                # TCN acts as structural mapper, picking up > 0.1 peaks
                peaks, _ = find_peaks(p_curve, height=0.1, distance=20)

                if len(peaks) < 3 or np.mean(p_curve[peaks]) < 0.15:
                    rejection_stage = "tcn_missed"
                else:
                    # Synthetic BLS
                    # TCN-GUIDED BLS ON REAL FLUX
                    # TCN acts as a gatekeeper (>=3 peaks required).
                    # BLS runs on ACTUAL photometry over the full period range.
                    # At 100 ppm noise, pure noise gives SDE~1-2 on real flux;
                    # real planets give SDE~10+ regardless of depth.
                    periods = np.linspace(0.5, 12.0, 2000)
                    durations = np.linspace(0.04, 0.25, 10)

                    # BLS on DETRENDED flux (modulation removed, transit preserved)
                    bls_model = BoxLeastSquares(time_ax, flux_detrended)
                    results = bls_model.power(periods, durations)

                    best_idx = np.argmax(results.power)
                    sde = (np.max(results.power) - np.mean(results.power)) / (np.std(results.power) + 1e-8)
                    best_period = results.period[best_idx]
                    t0_pred = results.transit_time[best_idx]
                    dur_pred = results.duration[best_idx]

                    if sde < 6.0:  # noise max ~5.0, planet min ~9.7 — 1.0 gap of safety
                        rejection_stage = "bls_missed"


                    else:
                        # EB Checks and Folded Validation
                        phase = (time_ax - t0_pred + 0.5 * best_period) % best_period - 0.5 * best_period

                        # EXACTLY ONE Batman Execution on the phase-folded trace
                        # Use tight window = 4× BLS-estimated duration so transit dominates chi2
                        dynamic_window = max(0.1, min(dur_pred * 4, 0.5))
                        val_res = validator.validate_candidate(phase, flux_detrended, 0.0, window_width=dynamic_window)

                        if val_res["verdict"] == "REJECTED":
                            rejection_stage = "validator_rejected"
                        else:
                            true_dur = val_res["params"]["dur"]
                            in_tran = np.abs(phase) < (true_dur / 2)
                            depth = np.median(flux_detrended) - np.median(flux_detrended[in_tran]) if np.sum(in_tran) > 2 else val_res["params"]["rp"]**2

                            # EB check on raw time-domain data (odd/even + depth gate)
                            if is_eclipsing_binary(time_ax, flux_detrended, best_period, t0_pred, true_dur):
                                rejection_stage = "eb_filter_false_alarm"
                            else:
                                pipeline_claims_planet = True

            if pipeline_claims_planet and truth == "Planet":
                tp += 1
                ptype = item["meta"].get("type", "Unknown")
                if ptype in per_type: per_type[ptype]["tp"] += 1
            elif not pipeline_claims_planet and truth != "Planet": tn += 1
            elif pipeline_claims_planet and truth != "Planet":
                fp += 1
                if truth == "EB": fp_reasons["was_eb"] += 1
                elif truth == "Pulsator": fp_reasons["was_pulsator"] += 1
                elif truth == "Modulation": fp_reasons["was_modulation"] += 1
                else: fp_reasons["was_noise"] += 1
            elif not pipeline_claims_planet and truth == "Planet":
                fn += 1
                fn_reasons[rejection_stage] += 1
                ptype = item["meta"].get("type", "Unknown")
                if ptype in per_type: per_type[ptype]["fn"] += 1

    print("\n==================================")
    print("      FAST EVALUATION REPORT      ")
    print("==================================")
    precision = tp / (tp + fp) if (tp + fp) > 0 else 0
    recall = tp / (tp + fn) if (tp + fn) > 0 else 0
    f1 = 2 * (precision * recall) / (precision + recall) if (precision + recall) > 0 else 0

    print(f"Total Evaluated : {len(dataset)}")
    print(f"True Positives  : {tp}")
    print(f"True Negatives  : {tn}")
    print(f"False Positives : {fp}")
    print(f"False Negatives : {fn}")
    print(f"----------------------------------")
    print(f"PRECISION : {precision:.2%}")
    print(f"RECALL    : {recall:.2%}")
    print(f"F1-SCORE  : {f1:.2%}")
    print(f"==================================\n")
    print("--- OPTIMIZATION DRILL-DOWN: FALSE NEGATIVES (Missed) ---")
    print(f"  TCN Missed entirely (Peaks < 3)         : {fn_reasons['tcn_missed']}")
    print(f"  BLS SDE < 7.0 (real flux)               : {fn_reasons['bls_missed']}")
    print(f"  Rejected as Pulsator (FP filter)        : {fn_reasons['pulsator_check']}")
    print(f"  Accidentally Rejected as EB             : {fn_reasons['eb_filter_false_alarm']}")
    print(f"  Batman Shape Validator Rejected         : {fn_reasons['validator_rejected']}")
    print("\n--- OPTIMIZATION DRILL-DOWN: FALSE POSITIVES (Junk) ---")
    print(f"  EBs mapped as Planets                   : {fp_reasons['was_eb']}")
    print(f"  Pulsators mapped as Planets             : {fp_reasons['was_pulsator']}")
    print(f"  Modulation mapped as Planets            : {fp_reasons['was_modulation']}")
    print(f"  Noise spikes mapped as Planets          : {fp_reasons['was_noise']}")

    print("\n--- PER PLANET CLASS BREAKDOWN ---")
    print(f"  {'Class':<14} {'Detected':>8} {'Missed':>7} {'Recall':>8}")
    print(f"  {'-'*40}")
    for ptype in planet_types:
        tp_t = per_type[ptype]["tp"]
        fn_t = per_type[ptype]["fn"]
        total_t = tp_t + fn_t
        rec_t = tp_t / total_t if total_t > 0 else 0
        print(f"  {ptype:<14} {tp_t:>8} {fn_t:>7} {rec_t:>8.1%}")

