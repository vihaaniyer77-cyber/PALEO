def mask_known_planets(time, flux, tic_id):
    """Mask confirmed planets, TOIs, and CTOIs to prevent re-detection."""
    mask = np.ones(len(time), dtype=bool)

    try:
        if NasaExoplanetArchive is None:
            raise RuntimeError("NasaExoplanetArchive not available")
        planets = NasaExoplanetArchive.query_criteria(
            table="pscomppars", where=f"tic_id='TIC {tic_id}'"
        )
        for row in (planets or []):
            try:
                period = float(row["pl_orbper"].value)
                t0     = float(row["pl_tranmid"].value) - 2457000.0
                dur    = float(row["pl_trandur"].value) / 24.0
                if period > 0 and dur > 0:
                    ph = (time - t0 + 0.5 * period) % period - 0.5 * period
                    mask &= np.abs(ph) > 0.6 * dur
            except Exception:
                pass
    except Exception:
        pass

    try:
        if NasaExoplanetArchive is None:
            raise RuntimeError("NasaExoplanetArchive not available")
        tois = NasaExoplanetArchive.query_criteria(
            table="toi", where=f"tic_id='{tic_id}'"
        )
        for row in (tois or []):
            try:
                period = float(row.get("pl_orbper", row.get("period", 0)))
                t0     = float(row.get("pl_tranmid", row.get("epoch", 0))) - 2457000.0
                dur    = float(row.get("pl_trandur", row.get("duration", 0))) / 24.0
                if period > 0 and dur > 0:
                    ph = (time - t0 + 0.5 * period) % period - 0.5 * period
                    mask &= np.abs(ph) > 0.6 * dur
            except Exception:
                pass
    except Exception:
        pass

    try:
        ctoi_df = get_ctoi_df()
        for _, row in ctoi_df[ctoi_df.get("TIC ID", pd.Series()) ==
                               str(tic_id)].iterrows():
            try:
                period = float(row.get("Period (days)", 0))
                t0     = float(row.get("Epoch (BJD)", 0)) - 2457000.0
                dur    = float(row.get("Duration (hrs)", 0)) / 24.0
                if period > 0 and dur > 0:
                    ph = (time - t0 + 0.5 * period) % period - 0.5 * period
                    mask &= np.abs(ph) > 0.6 * dur
            except Exception:
                pass
    except Exception:
        pass

    flux_out = flux.copy()
    flux_out[~mask] = 1.0
    return flux_out


