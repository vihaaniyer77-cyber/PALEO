def get_bad_tics():
    """Downloads known EBs and FPs to build a blocklist."""
    bad_tics = set()
    print("[INFO] Building blocklist (catalog-based)...")

    try:
        eb_df = pd.read_csv(TESS_EBS_URL, comment="#")
        col   = next((c for c in ["tic_id", "ID"] if c in eb_df.columns),
                     eb_df.columns[0])
        bad_tics.update(eb_df[col].astype(str).tolist())
        print(f"   [OK] {len(bad_tics)} known EBs loaded.")
    except Exception as e:
        print(f"   [WARN] TESS-EBs failed: {e}")

    try:
        toi_df  = pd.read_csv(TOI_LIST_URL)
        fp_mask = pd.Series(False, index=toi_df.index)
        for col in ["tfopwg_disp", "toi_p_disposition"]:
            if col in toi_df.columns:
                fp_mask |= toi_df[col].isin(["FP", "FA"])
        if fp_mask.any():
            bad_tics.update(toi_df[fp_mask]["tic_id"].astype(str).tolist())
        print(f"   [OK] Total blocklist: {len(bad_tics)} TICs.")
    except Exception as e:
        print(f"   [WARN] TOI list failed: {e}")

    return bad_tics


