def detrend_flux(flux, window=241):
    """Rolling-median detrend (~4.8 d at 30-min cadence).
    Removes 1-15 d stellar modulation; transit dips (0.04-0.2 d)
    are <5 % of the window → median is unaffected."""
    trend = median_filter(flux, size=window, mode="nearest")
    return flux / np.clip(trend, 1e-6, None)


def is_pulsator(time, flux, power_threshold=1.0):
    """High-frequency LS check (periods 0.5-6 hr).
    Calibrated threshold: pulsators give peak power 1.2-77,
    transit harmonics give 0.04-0.28 — no overlap."""
    f_min = 24.0 / 6.0       # 4 cpd  (6 hr period)
    f_max = 24.0 / 0.5       # 48 cpd (30 min period)
    freq  = np.linspace(f_min, f_max, 1000)
    ls    = LombScargle(time, flux - np.median(flux), normalization="model")
    return np.max(ls.power(freq)) > power_threshold


def is_eclipsing_binary(time, flux, period, t0, duration):
    """3-gate EB filter (from calibrated evaluate_pipeline.py).

    Gate 1  – absolute depth  > 2.5 % (planet max ≈ 2 %)
    Gate 2  – secondary eclipse at t0 + P/2  > 10 % of primary AND > 2σ
    Gate 3  – odd/even asymmetry > 30 %
    """
    global_median = np.median(flux)
    global_std    = np.std(flux)
    half_dur      = max(duration / 2.0, 0.02)

    # --- Measure primary depth (15th-pctile catches V-shapes) ---
    transit_depths = []
    t_scan = t0 % period
    while t_scan < time[-1]:
        if t_scan >= time[0]:
            mask = np.abs(time - t_scan) < half_dur
            if mask.sum() >= 3:
                d = global_median - np.percentile(flux[mask], 15)
                transit_depths.append(d)
        t_scan += period

    if len(transit_depths) == 0:
        return False
    mean_depth = np.mean(transit_depths)

    # Sanity: must be a real dip
    if mean_depth < 2.0 * global_std:
        return False

    # Gate 1: absolute depth
    if mean_depth > 0.025:
        return True

    # Gate 2: secondary eclipse at half-period
    secondary_depths = []
    t_sec = (t0 + period / 2.0) % period
    while t_sec < time[-1]:
        if t_sec >= time[0]:
            mask = np.abs(time - t_sec) < half_dur
            if mask.sum() >= 3:
                secondary_depths.append(
                    global_median - np.percentile(flux[mask], 15)
                )
        t_sec += period

    if secondary_depths:
        sec_depth = np.mean(secondary_depths)
        if sec_depth > 0.10 * mean_depth and sec_depth > 2.0 * global_std:
            return True

    # Gate 3: odd/even asymmetry
    odd_depths, even_depths = [], []
    n = 0
    t_scan = t0 % period
    while t_scan < time[-1]:
        if t_scan >= time[0]:
            mask = np.abs(time - t_scan) < half_dur
            if mask.sum() >= 3:
                d = global_median - np.percentile(flux[mask], 15)
                (odd_depths if n % 2 == 0 else even_depths).append(d)
            n += 1
        t_scan += period

    if len(odd_depths) >= 2 and len(even_depths) >= 2:
        d_odd  = np.mean(odd_depths)
        d_even = np.mean(even_depths)
        if (d_odd + d_even) > 0:
            if abs(d_odd - d_even) / (d_odd + d_even) > 0.30:
                return True

    return False


class FoldedValidator:
    """Batman chi² gain validator (phase-folded, then fit).
    Adapted from evaluate_pipeline.py."""

    def validate_candidate(self, phase, flux, t_center=0.0,
                           window_width=0.3):
        mask    = np.abs(phase - t_center) < (window_width / 2.0)
        t_local = phase[mask]
        f_local = flux[mask]

        if len(t_local) < 5:
            return {"verdict": "REJECTED", "gain": 0.0, "params": {}}

        robust_mid = np.median(np.sort(f_local)[int(len(f_local) * 0.2):]) \
                     if len(f_local) > 5 else np.median(f_local)
        chi2_flat  = np.sum((f_local - robust_mid) ** 2) or 1e-10

        def transit_model(params, t):
            t0_, rp_, dur_ = params
            p = batman.TransitParams()
            p.t0  = t0_
            p.per = 10000.0
            p.rp  = rp_
            p.a   = max(2.0, 10000.0 / (np.pi * dur_))
            p.inc = 90.0; p.ecc = 0.0; p.w = 90.0
            p.u   = [0.3, 0.3]; p.limb_dark = "quadratic"
            return batman.TransitModel(p, t).light_curve(p) * robust_mid

        def objective(params):
            return np.sum((f_local - transit_model(params, t_local)) ** 2)

        bounds  = [(t_center - 0.2, t_center + 0.2), (0.001, 0.8), (0.01, 1.0)]
        guesses = [t_center, 0.05, 0.1]

        try:
            res = minimize(objective, guesses, bounds=bounds, method="L-BFGS-B")
            chi2_transit = res.fun
            best = res.x
        except Exception as e:
            return {"verdict": "ERROR", "gain": 0.0, "params": {}, "error": str(e)}

        gain    = 1.0 - (chi2_transit / chi2_flat)
        verdict = "VALIDATED" if gain > 0.001 else "REJECTED"
        return {"verdict": verdict, "gain": gain,
                "params": {"t0": best[0], "rp": best[1], "dur": best[2]}}


