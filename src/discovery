def process_tess_sector(target_name=None, sector_num=SECTOR,
                         max_targets=MAX_TARGETS):
    """Download and normalize TESS LCs for a sector via MAST/lightkurve."""
    print(f"[INFO] Querying MAST for TESS Sector {sector_num}...")
    get_ctoi_df()
    bad_tics = get_bad_tics()

    if target_name:
        tic_clean = str(target_name).replace("TIC", "").strip()
        if tic_clean in bad_tics:
            print(f"[WARN] {target_name} is in blocklist. Skipping.")
            return []
        chosen_tics = [target_name]
    else:
        try:
            obs = Observations.query_criteria(
                obs_collection="TESS",
                sequence_number=sector_num,
                dataproduct_type="timeseries",
            )
            if len(obs) == 0:
                print(f"[ERROR] No observations for Sector {sector_num}.")
                return []
            obs_df    = obs.to_pandas()
            all_tics  = obs_df["target_name"].astype(str).unique()
            clean_tics = [f"TIC {t}" for t in all_tics if t not in bad_tics]
            print(f"   {len(clean_tics)} targets after blocklist filter.")

            import random
            random.seed(42)
            random.shuffle(clean_tics)
            chosen_tics = clean_tics[:min(max_targets, len(clean_tics))]
            print(f"   Selected {len(chosen_tics)} targets.")
        except Exception as e:
            print(f"[ERROR] MAST query failed: {e}")
            return []

    sector_dir = os.path.join(DATA_DIR, f"sector_{sector_num}")
    os.makedirs(sector_dir, exist_ok=True)
    saved_files = []

    print(f"[INFO] Downloading {len(chosen_tics)} lightcurves...")
    for tic_name in tqdm(chosen_tics, desc="Downloading"):
        try:
            out_file = os.path.join(
                sector_dir,
                f"{tic_name.replace(' ', '_')}_sec{sector_num}.csv"
            )
            if os.path.exists(out_file):
                saved_files.append(out_file)
                continue

            sr = lk.search_lightcurve(
                tic_name, mission="TESS", sector=sector_num,
                author="SPOC", exptime=120
            )
            if len(sr) == 0:
                continue

            lc = sr.download_all().stitch().remove_nans().remove_outliers(sigma=5)
            if len(lc.time) < 100:
                continue

            lc_binned = lc.bin(time_bin_size=0.020833)   # 30-min bins
            if len(lc_binned.time) < 50:
                continue

            flux = lc_binned.flux.value.astype(float)
            time = lc_binned.time.value.astype(float)
            ok   = np.isfinite(flux) & np.isfinite(time)
            flux, time = flux[ok], time[ok]
            if len(flux) < 50:
                continue

            # Normalise to median ≈ 1
            med = np.median(flux)
            if med == 0:
                continue
            norm_flux = flux if 0.95 < med < 1.05 else flux / med

            # Mask known transiting planets / TOIs / CTOIs
            tic_id_num = tic_name.replace("TIC ", "").strip()
            norm_flux  = mask_known_planets(time, norm_flux, tic_id_num)

            pd.DataFrame({"time": time, "flux": norm_flux}).to_csv(
                out_file, index=False
            )
            saved_files.append(out_file)

        except Exception:
            pass

    print(f"[INFO] Saved {len(saved_files)} LCs to {sector_dir}.")
    return sector_dir


