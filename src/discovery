# 6. MAIN INFERENCE + VALIDATION PIPELINE
# ==============================================================
def run_pipeline_on_sector(sector_dir, model, output_file,
                            sde_threshold=6.0, batch_size=64):
    """
    Full PALEO pipeline on all CSVs in sector_dir.

    For each target:
    1.  Pulsator pre-check  (LS power > 1.0 → skip)
    2.  TCN structural gate (≥3 peaks required)
    3.  BLS on detrended flux (SDE > 6.0)
    4.  Batman phase-fold validator (chi² gain > 0.001)
    5.  Eclipsing binary rejection (3-gate)
    6.  Save planet candidate + generate plot
    """
    validator   = FoldedValidator()
    csv_files   = (glob.glob(os.path.join(sector_dir, "*.csv"))
                   if os.path.isdir(sector_dir) else [])

    print(f"[INFO] Running PALEO on {len(csv_files)} LCs (SDE > {sde_threshold})...")

    candidates  = []
    n_pulsator  = 0
    n_tcn_fail  = 0
    n_bls_fail  = 0
    n_bat_fail  = 0
    n_eb_reject = 0

    # ── Batch TCN inference ─────────────────────────────────────
    all_data = []
    for fpath in csv_files:
        try:
            df   = pd.read_csv(fpath)
            flux = np.nan_to_num(df["flux"].values.astype(float), nan=1.0)
            time = df["time"].values.astype(float)
            tic  = (os.path.basename(fpath).replace("TIC_", "")
                                           .split("_sec")[0])
            all_data.append((fpath, tic, time, flux))
        except Exception:
            pass

    # Filter pulsators before TCN (saves GPU time)
    clean_data = []
    for fpath, tic, time, flux in all_data:
        if is_pulsator(time, flux):
            n_pulsator += 1
        else:
            clean_data.append((fpath, tic, time, flux))

    print(f"   Pulsators removed  : {n_pulsator}")
    print(f"   Targets for TCN    : {len(clean_data)}")

    # Padded batch TCN
    for i in tqdm(range(0, len(clean_data), batch_size), desc="TCN Inference"):
        batch = clean_data[i:i + batch_size]
        max_len = max(len(d[3]) for d in batch)
        padded  = np.array([
            np.pad(d[3] - 1.0, (0, max_len - len(d[3])), constant_values=0.0)
            for d in batch
        ], dtype=np.float32)

        x_tensor = torch.tensor(padded, device=DEVICE).unsqueeze(1)
        with torch.no_grad():
            logits = model(x_tensor)
            probs  = torch.sigmoid(logits[:, 0, :]).cpu().numpy()

        for b_idx, (fpath, tic, time, flux) in enumerate(batch):
            p_curve = probs[b_idx][:len(flux)]
            peaks, _ = find_peaks(p_curve, height=0.1, distance=20)

            # Gate 2: structural (≥ 3 peaks)
            if len(peaks) < 3 or np.mean(p_curve[peaks]) < 0.15:
                n_tcn_fail += 1
                continue

            # Gate 3: BLS on detrended flux
            flux_det = detrend_flux(flux)
            periods  = np.linspace(0.5, 12.0, 2000)
            durations = np.linspace(0.04, 0.25, 10)

            try:
                bls = BoxLeastSquares(time, flux_det)
                res = bls.power(periods, durations)
            except Exception:
                n_bls_fail += 1
                continue

            best_idx    = np.argmax(res.power)
            sde         = ((np.max(res.power) - np.mean(res.power))
                           / (np.std(res.power) + 1e-8))
            best_period = float(res.period[best_idx])
            t0_pred     = float(res.transit_time[best_idx])
            dur_pred    = float(res.duration[best_idx])

            if sde < sde_threshold:
                n_bls_fail += 1
                continue

            # Gate 4: Batman chi² shape fit
            phase        = (time - t0_pred + 0.5 * best_period) % best_period \
                           - 0.5 * best_period
            dyn_window   = max(0.1, min(dur_pred * 4, 0.5))
            val_res      = validator.validate_candidate(
                phase, flux_det, 0.0, window_width=dyn_window
            )

            if val_res["verdict"] != "VALIDATED":
                n_bat_fail += 1
                continue

            true_dur = val_res["params"]["dur"]

            # Gate 5: EB rejection
            if is_eclipsing_binary(time, flux_det, best_period,
                                   t0_pred, true_dur):
                n_eb_reject += 1
                continue

            # Survived all gates — record candidate
            in_tran = np.abs(phase) < (true_dur / 2)
            depth   = (np.median(flux_det) - np.median(flux_det[in_tran])
                       if in_tran.sum() > 2 else val_res["params"]["rp"] ** 2)

            print(f"[PLANET] TIC {tic}  P={best_period:.4f} d  "
                  f"SDE={sde:.1f}  depth={depth*1e6:.0f} ppm")

            # Generate plot
            out_dir = os.path.dirname(output_file) or OUTPUT_DIR
            plot_discovery(time, flux_det, best_period, t0_pred,
                           true_dur, tic, out_dir)

            candidates.append({
                "tic_id":   tic,
                "period_d": round(best_period, 6),
                "sde":      round(sde, 2),
                "t0_btjd":  round(t0_pred, 5),
                "duration_hr": round(true_dur * 24, 3),
                "depth_ppm":   round(depth * 1e6, 1),
                "phys_gain":   round(val_res["gain"], 4),
                "pred_rp":     round(val_res["params"]["rp"], 5),
            })

    # Save catalog
    print(f"\n[SUMMARY]")
    print(f"  Pulsator-rejected  : {n_pulsator}")
    print(f"  TCN-failed (< 3 peaks) : {n_tcn_fail}")
    print(f"  BLS-failed (SDE < {sde_threshold}) : {n_bls_fail}")
    print(f"  Batman-rejected    : {n_bat_fail}")
    print(f"  EB-rejected        : {n_eb_reject}")
    print(f"  Planet candidates  : {len(candidates)}")

    if candidates:
        cand_df = pd.DataFrame(candidates).sort_values("sde", ascending=False)
        cand_df.to_csv(output_file, index=False)
        print(f"[OUTPUT] Catalog → {output_file}")
        return cand_df

    print("[INFO] No planet candidates found for this sector.")
    return pd.DataFrame()


