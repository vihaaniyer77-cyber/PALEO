class Chomp1d(nn.Module):
    def __init__(self, chomp_size):
        super().__init__()
        self.chomp_size = int(chomp_size)

    def forward(self, x):
        return x[:, :, :-self.chomp_size] if self.chomp_size > 0 else x


class ResidualTCNBlock(nn.Module):
    def __init__(self, in_ch, out_ch, kernel_size, dilation,
                 dropout=0.15, groups_gn=None):
        super().__init__()
        padding = (kernel_size - 1) * dilation
        self.conv1  = nn.Conv1d(in_ch, out_ch, kernel_size,
                                padding=padding, dilation=dilation)
        self.chomp1 = Chomp1d(padding)
        self.n1     = (nn.GroupNorm(max(1, min(groups_gn, out_ch)), out_ch)
                       if groups_gn else nn.BatchNorm1d(out_ch))
        self.relu1  = nn.ReLU()
        self.drop1  = nn.Dropout(dropout)

        self.conv2  = nn.Conv1d(out_ch, out_ch, kernel_size,
                                padding=padding, dilation=dilation)
        self.chomp2 = Chomp1d(padding)
        self.n2     = (nn.GroupNorm(max(1, min(groups_gn, out_ch)), out_ch)
                       if groups_gn else nn.BatchNorm1d(out_ch))
        self.relu2  = nn.ReLU()
        self.drop2  = nn.Dropout(dropout)

        self.downsample = nn.Conv1d(in_ch, out_ch, 1) if in_ch != out_ch else None
        self.relu       = nn.ReLU()

    def forward(self, x):
        out = self.drop1(self.relu1(self.n1(self.chomp1(self.conv1(x)))))
        out = self.drop2(self.relu2(self.n2(self.chomp2(self.conv2(out)))))
        res = x if self.downsample is None else self.downsample(x)
        return self.relu(out + res)


class TCNEventDetector(nn.Module):
    def __init__(self, in_ch=1, hidden=128, depth=8, kernel_size=5,
                 dropout=0.15, groups_gn=None, out_ch=2):
        super().__init__()
        dilations = [2 ** i for i in range(depth)]
        blocks, c_in = [], in_ch
        for d in dilations:
            blocks.append(ResidualTCNBlock(c_in, hidden, kernel_size,
                                           d, dropout, groups_gn))
            c_in = hidden
        self.backbone = nn.Sequential(*blocks)
        self.head     = nn.Conv1d(hidden, out_ch, 1)

    def forward(self, x):
        return self.head(self.backbone(x))


def load_model(path):
    if not os.path.exists(path):
        print(f"[ERROR] Model file '{path}' not found.")
        return None
    print(f"[INFO] Loading model from {path}...")
    try:
        ckpt       = torch.load(path, map_location=DEVICE)
        state_dict = ckpt.get("model_state", ckpt)
        config     = ckpt.get("config", {})

        hidden  = config.get("hidden", 128)
        depth   = config.get("depth", 8)
        kernel  = config.get("kernel_size", 5)
        dropout = config.get("dropout", 0.15)
        gn      = config.get("groups_gn", 8)
        if any("bn1.weight" in k for k in state_dict):
            gn = None

        model = TCNEventDetector(in_ch=1, hidden=hidden, depth=depth,
                                 kernel_size=kernel, dropout=dropout,
                                 groups_gn=gn).to(DEVICE)
        # Remap legacy norm layer names
        new_sd = {}
        for k, v in state_dict.items():
            new_k = k.replace("bn1", "n1").replace("gn1", "n1") \
                      .replace("bn2", "n2").replace("gn2", "n2")
            new_sd[new_k] = v
        model.load_state_dict(new_sd, strict=False)
        model.eval()
        return model
    except Exception as e:
        print(f"[ERROR] Failed to load model: {e}")
        return None


