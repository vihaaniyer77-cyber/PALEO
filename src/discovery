def plot_discovery(time, flux, period, t0, duration, tic_id, output_dir):
    """Phase-folded discovery plot matching reference style:
    grey scatter, Phase [D] x-axis, clean title."""
    plots_dir = os.path.join(output_dir, "plots")
    os.makedirs(plots_dir, exist_ok=True)

    # Phase-fold
    phase = (time - t0 + 0.5 * period) % period - 0.5 * period  # days

    dur_hr  = duration * 24.0
    x_limit = min(period / 2.0, 1.5)   # show ±1.5 d or ±P/2, whichever is less

    fig, (ax1, ax2) = plt.subplots(
        2, 1, figsize=(12, 8),
        gridspec_kw={"height_ratios": [1, 1.4]}
    )

    # ── Panel 1: Full light curve with transit markers ──────────────
    ax1.scatter(time, flux, s=3, c="#444444", alpha=0.4, rasterized=True)

    t_start, t_end = time.min(), time.max()
    n0 = int(np.floor((t_start - t0) / period))
    n1 = int(np.ceil((t_end   - t0) / period))
    for n in range(n0, n1 + 1):
        tt = t0 + n * period
        if t_start <= tt <= t_end:
            ax1.axvline(tt, color="tomato", alpha=0.6, linewidth=1.2, linestyle="--")

    ax1.set_title(
        f"TIC {tic_id}  ·  Full LC  |  P = {period:.4f} d  |  dur = {dur_hr:.2f} hr",
        fontsize=11
    )
    ax1.set_xlabel("Time (BTJD)", fontsize=10)
    ax1.set_ylabel("Normalized Flux", fontsize=10)
    ax1.grid(True, alpha=0.2, linewidth=0.5)
    ax1.tick_params(labelsize=9)

    # ── Panel 2: Phase-folded ─────────────────────────────────────
    ax2.scatter(phase, flux, s=4, c="#333333", alpha=0.45,
                label=f"\u00b7 TIC {tic_id}", rasterized=True)

    # Subtle shaded transit window
    ax2.axvspan(-duration / 2, duration / 2, alpha=0.08,
                color="steelblue", label="Transit window")

    ax2.set_title(
        f"TIC {tic_id} \u2014 Folded (P={period:.4f} d, dur={dur_hr:.2f} hr)",
        fontsize=11
    )
    ax2.set_xlabel("Phase [D]", fontsize=10)
    ax2.set_ylabel("Normalized Flux", fontsize=10)
    ax2.set_xlim(-x_limit, x_limit)
    ax2.legend(loc="upper right", fontsize=9, framealpha=0.7)
    ax2.grid(True, alpha=0.2, linewidth=0.5)
    ax2.tick_params(labelsize=9)

    plt.tight_layout()
    out_path = os.path.join(plots_dir, f"TIC_{tic_id}_P{period:.4f}.png")
    plt.savefig(out_path, dpi=150, bbox_inches="tight")
    plt.close()
    print(f"   [PLOT] Saved → {out_path}")


