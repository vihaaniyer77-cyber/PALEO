def hours_to_days(h): return h / 24.0

def mad_sigma(x):
    x = np.asarray(x, dtype=float)
    x = x[np.isfinite(x)]
    if x.size < 5:
        return np.nan
    med = np.median(x)
    mad = np.median(np.abs(x - med))
    return 1.4826 * mad

def count_events(flag_bool):
    f = np.asarray(flag_bool, dtype=bool)
    if f.size == 0:
        return 0
    return int(np.sum((f[1:] & ~f[:-1])) + (1 if f[0] else 0))

def ensure_cache_present():
    if not os.path.isdir(CACHE_DIR):
        if os.path.exists(ZIP_PATH):
            print(f"[INFO] {CACHE_DIR}/ not found. Unzipping {ZIP_PATH} ...")
            with zipfile.ZipFile(ZIP_PATH, "r") as z:
                z.extractall(".")
            print("[INFO] Unzip complete.")
        else:
            raise FileNotFoundError(f"Missing {CACHE_DIR}/ and also missing {ZIP_PATH}")

def fits_for_kepid(kepid: int) -> str:
