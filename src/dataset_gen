# OPTIONAL SANITY PLOTS (10 transit + 10 flare)
# ============================================================
if MAKE_SANITY_PLOTS:
    import matplotlib.pyplot as plt

    rngp = np.random.default_rng(PLOT_RNG_SEED)

    def detrend_for_plot_only(x, w=DETREND_W_CAD):
        s = pd.Series(np.asarray(x, float))
        tr = s.rolling(int(w), center=True, min_periods=max(3, int(w)//2)).median().to_numpy()
        tr = np.nan_to_num(tr, nan=0.0)
        return (np.asarray(x, float) - tr).astype(np.float32)

    transit_idx = np.where((Y[:, :, 0] * M[:, :, 0]).sum(axis=1) > 0)[0]
    flare_idx   = np.where((Y[:, :, 1] * M[:, :, 0]).sum(axis=1) > 0)[0]

    def pick(idxs, n):
        if idxs.size == 0:
            return []
        if idxs.size <= n:
            return idxs.tolist()
        return rngp.choice(idxs, size=n, replace=False).tolist()

    pick_t = pick(transit_idx, N_TRANSIT_PLOTS)
    pick_f = pick(flare_idx,   N_FLARE_PLOTS)

    def plot_one(i, title):
        x = X[i, :, 0]
        m = M[i, :, 0]
        yC = Y[i, :, 0]
        yF = Y[i, :, 1]
        t0 = t_starts[i]
        xh = (np.arange(T) * DT_DAYS) * 24.0

        xd = detrend_for_plot_only(x)

        plt.figure(figsize=(12, 4))
        plt.plot(xh, x, lw=1, label="x (median norm, centered)")
        plt.plot(xh, xd, lw=1, label="x_detrended (plot-only)")
        amp = max(float(np.nanmax(np.abs(xd))), 1e-4)
        plt.plot(xh, -0.8*amp*yC, lw=1, label="center heatmap (scaled)")
        plt.plot(xh,  0.8*amp*yF, lw=1, label="flare flag (scaled)")
        plt.scatter(xh[m < 0.5], np.full(int(np.sum(m < 0.5)), -amp), s=8, label="missing (M=0)")
        plt.axhline(0.0, lw=1)
        plt.title(f"{title} | win={i} | KIC={kepid_per_window[i]} | t0={t0:.3f}")
        plt.xlabel("Hours from window start")
        plt.ylabel("Flux")
        plt.legend(loc="best")
        plt.tight_layout()
        plt.show()

    print("\n--- SANITY: TRANSIT WINDOWS ---")
    for i in pick_t:
        plot_one(i, "TRANSIT")

    print("\n--- SANITY: FLARE WINDOWS ---")
    for i in pick_f:
        plot_one(i, "FLARE")
