# ============================================================
# SPLIT BY STAR (flare-aware, no leakage)
# ============================================================
unique_stars = np.unique(kepid_per_window)
rng = np.random.default_rng(SPLIT_SEED)

flare_any_window = (Y[:, :, 1] * M[:, :, 0]).sum(axis=1) > 0
flare_stars = np.unique(kepid_per_window[flare_any_window])
nonflare_stars = np.setdiff1d(unique_stars, flare_stars, assume_unique=False)

flare_stars = flare_stars.copy(); rng.shuffle(flare_stars)
nonflare_stars = nonflare_stars.copy(); rng.shuffle(nonflare_stars)

n_stars = unique_stars.size
n_train = int(round(TRAIN_FRAC * n_stars))
n_val   = int(round(VAL_FRAC   * n_stars))
n_test  = n_stars - n_train - n_val

k_val  = int(min(K_FLARE_STARS_VAL,  len(flare_stars), n_val))
k_test = int(min(K_FLARE_STARS_TEST, max(0, len(flare_stars) - k_val), n_test))

val_flare  = flare_stars[:k_val]
test_flare = flare_stars[k_val:k_val + k_test]
remain_flare = flare_stars[k_val + k_test:]

def take(arr, k):
    k = max(0, int(k))
    return arr[:k], arr[k:]

val_need  = n_val  - len(val_flare)
test_need = n_test - len(test_flare)

val_fill_nf, nonflare_stars = take(nonflare_stars, val_need)
val_need -= len(val_fill_nf)
val_fill_fl, remain_flare = take(remain_flare, val_need)

test_fill_nf, nonflare_stars = take(nonflare_stars, test_need)
test_need -= len(test_fill_nf)
test_fill_fl, remain_flare = take(remain_flare, test_need)

val_stars   = np.concatenate([val_flare,  val_fill_nf,  val_fill_fl]).astype(np.int64)
test_stars  = np.concatenate([test_flare, test_fill_nf, test_fill_fl]).astype(np.int64)
train_stars = np.concatenate([remain_flare, nonflare_stars]).astype(np.int64)

assert len(val_stars) == n_val
assert len(test_stars) == n_test
assert len(train_stars) == n_train

all_assigned = np.concatenate([train_stars, val_stars, test_stars])
assert np.unique(all_assigned).size == unique_stars.size, "Not all stars assigned exactly once."

is_train = np.isin(kepid_per_window, train_stars)
is_val   = np.isin(kepid_per_window, val_stars)
is_test  = np.isin(kepid_per_window, test_stars)

train_idx = np.where(is_train)[0]
val_idx   = np.where(is_val)[0]
test_idx  = np.where(is_test)[0]

def _flare_windows(idxs):
    idxs = np.asarray(idxs, dtype=int)
    return int(np.sum(((Y[idxs, :, 1] * M[idxs, :, 0]).sum(axis=1) > 0)))

print("\n=== SPLIT SUMMARY (BY STAR) ===")
print("Total stars:", int(n_stars))
print("Flare-active stars:", int(len(flare_stars)), "| Nonflare stars:", int(len(np.setdiff1d(unique_stars, flare_stars))))
print("Target star counts: train=", n_train, "val=", n_val, "test=", n_test)
print("Actual star counts: train=", len(train_stars), "val=", len(val_stars), "test=", len(test_stars))
print("Flare windows | train:", _flare_windows(train_idx),
      "val:", _flare_windows(val_idx),
      "test:", _flare_windows(test_idx))

splits = {
