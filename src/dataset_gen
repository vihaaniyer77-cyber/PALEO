stars = stars[["kepid", "hostname"]].copy()

# Merge and prefer starlist hostname (your old behavior)
m = m.merge(stars, on="kepid", how="left", suffixes=("", "_starlist"))
m["hostname"] = m["hostname"].fillna("").astype(str)
if "hostname_starlist" in m.columns:
    hs = m["hostname_starlist"].fillna("").astype(str)
    m["hostname"] = np.where(hs.str.strip().ne(""), hs, m["hostname"])

print("[INFO] Cached stars usable before planet filter:", len(m))
print("[INFO] T =", T, "| DT_DAYS =", DT_DAYS, "| NN_TOL (days) =", NN_TOL)

X_list, Y_list, M_list = [], [], []
kepid_list, host_list, tstart_list = [], [], []

truth_rows = []
events_by_window_lines = []

flare_events_per_star = {}
flare_windows_per_star = {}
num_planets_per_star = {}
planet_names_per_star = {}

skipped_zero_planets = 0
stars_with_windows = 0

for _, row in m.iterrows():
    kepid = int(row["kepid"])
    hostname = str(row.get("hostname", "")).strip()
    target = f"KIC {kepid}"

    try:
        planets = fetch_ephemerides_for_host(hostname)
        if len(planets) == 0:
            skipped_zero_planets += 1
            print(f"[SKIP] {target} | planets=0 (no ephemerides)")
            continue

        fits_path = fits_for_kepid(kepid)
        if not (os.path.exists(fits_path) and os.path.getsize(fits_path) > 0):
            raise FileNotFoundError(f"Missing/empty FITS: {fits_path}")

        lc = lk.read(fits_path)

        # full LC time range (finite only)
        t_all = np.asarray(lc.time.value, float)
        f_all = np.asarray(lc.flux.value, float)
        good = np.isfinite(t_all) & np.isfinite(f_all)
        t_all, f_all = t_all[good], f_all[good]
        if t_all.size < 10:
            print(f"[SKIP] {target} | too few finite points")
            continue
        order = np.argsort(t_all)
        t_all, f_all = t_all[order], f_all[order]
        t_min, t_max = float(t_all.min()), float(t_all.max())

        # truth list (global)
        truth_list = enumerate_transit_centers_for_star(lc, planets, t_min, t_max)

        # flare flags over full LC
        t_full, flare_flag_full = detect_flares_full_lc(lc)
        flare_events_per_star[kepid] = count_events(flare_flag_full)

        num_planets_per_star[kepid] = len(planets)
        planet_names_per_star[kepid] = [p["name"] for p in planets]

        # windows
        windows = window_lc(lc)
        flare_w_count = 0
        win_added = 0

        for (tw, fw, start, end) in windows:
            t_grid, x_raw, M0 = build_fixed_grid_nn(tw, fw, start)

            x = normalize_window_median(x_raw, M0)[:, None]  # (T,1)
            Mw = M0.astype(np.float32)[:, None]              # (T,1)

            evs = truth_events_in_window(start, start + WINDOW_DAYS, truth_list)
            y_center = center_heatmap(evs)                   # (T,)

            y_flare = map_flags_to_grid_nn(t_full, flare_flag_full, t_grid)
            y_flare = y_flare * (M0 > 0).astype(np.float32)

            if (y_flare * (M0 > 0)).sum() > 0:
                flare_w_count += 1

            Yw = np.stack([y_center, y_flare], axis=1).astype(np.float32)  # (T,2)

            X_list.append(x.astype(np.float32))
            Y_list.append(Yw)
            M_list.append(Mw)

            kepid_list.append(kepid)
            host_list.append(hostname)
            tstart_list.append(float(start))

            events_by_window_lines.append(json.dumps({
                "kepid": kepid,
                "hostname": hostname,
                "t_start": float(start),
                "t_end": float(start + WINDOW_DAYS),
                "events": evs
            }))

            win_added += 1

        flare_windows_per_star[kepid] = flare_w_count

        for ev in truth_list:
            truth_rows.append({
                "kepid": kepid,
                "hostname": hostname,
                "pl_name": ev["pl_name"],
                "P_days": ev["P_days"],
                "t_c": ev["t_c"],
                "dur_eff_days": ev["dur_eff_days"],
            })

        if win_added > 0:
            stars_with_windows += 1

        print(f"[OK] {target} | windows={win_added} | planets={len(planets)} | flare_events={flare_events_per_star[kepid]} | flare_windows={flare_w_count}")

    except Exception as e:
        print(f"[SKIP] {target} failed: {e}")

if len(X_list) == 0:
    raise RuntimeError("No windows produced (after skipping planets==0 stars).")

X = np.stack(X_list, axis=0).astype(np.float32)   # (N,T,1)
