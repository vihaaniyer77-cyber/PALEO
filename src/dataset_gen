_EPHEM_CACHE = {}

def fetch_ephemerides_for_host(hostname):
    hn = str(hostname).strip()
    if hn == "" or hn.lower() == "nan":
        return []
    if hn in _EPHEM_CACHE:
        return _EPHEM_CACHE[hn]

    query = f"""
        SELECT pl_name, pl_orbper, pl_tranmid, pl_trandur
        FROM ps
        WHERE hostname = '{hn.replace("'", "''")}'
          AND pl_orbper IS NOT NULL
          AND pl_tranmid IS NOT NULL
          AND pl_trandur IS NOT NULL
    """.strip().replace("\n", " ")

    url = "https://exoplanetarchive.ipac.caltech.edu/TAP/sync"
    params = {"query": query, "format": "json"}

    try:
        rows = requests.get(url, params=params, timeout=30).json()
    except Exception:
        _EPHEM_CACHE[hn] = []
        return []

    planets_by_name = {}
    for row in rows:
        try:
            name = str(row["pl_name"]).strip()
            P = float(row["pl_orbper"])
            t0 = float(row["pl_tranmid"])
            dur_hours = float(row["pl_trandur"])
            if not (np.isfinite(P) and P > 0 and np.isfinite(t0) and np.isfinite(dur_hours) and dur_hours > 0):
                continue
            dur_days = dur_hours / 24.0
            if name not in planets_by_name:
                planets_by_name[name] = {"name": name, "P_days": P, "t0_bjd": t0, "dur_days_cat": dur_days}
        except Exception:
            continue

    planets = list(planets_by_name.values())
    _EPHEM_CACHE[hn] = planets
    return planets

def clamp_duration_days(P_days, dur_days_cat):
    if not (np.isfinite(dur_days_cat) and dur_days_cat > 0):
        dur = DEFAULT_DUR_HRS / 24.0
    else:
        dur = float(dur_days_cat)

    dur = max(dur, DUR_MIN_CAD * DT_DAYS)
    dur = min(dur, DUR_MAX_HRS / 24.0)
    if np.isfinite(P_days) and P_days > 0:
        dur = min(dur, DUR_MAX_FRAC_P * P_days)
    return float(dur)

# -----------------------------
# FIXED GRID: nearest-neighbor mapping within 0.5 cadence
# -----------------------------
def build_fixed_grid_nn(tw, fw, start):
    t_grid = start + DT_DAYS * np.arange(T, dtype=float)

    good = np.isfinite(tw) & np.isfinite(fw)
    tw2 = np.asarray(tw[good], dtype=float)
    fw2 = np.asarray(fw[good], dtype=float)

    X = np.zeros(T, dtype=float)
    M = np.zeros(T, dtype=np.uint8)

    if tw2.size < 2:
        return t_grid, X, M

    order = np.argsort(tw2)
    tws = tw2[order]
    fws = fw2[order]

    idx = np.searchsorted(tws, t_grid, side="left")
    left = np.clip(idx - 1, 0, tws.size - 1)
    right = np.clip(idx, 0, tws.size - 1)

    d_left = np.abs(t_grid - tws[left])
    d_right = np.abs(t_grid - tws[right])

    choose_right = d_right < d_left
    nearest = np.where(choose_right, right, left)
    d_near = np.minimum(d_left, d_right)

    ok = d_near < NN_TOL
    M[ok] = 1
    X[ok] = fws[nearest[ok]]

    return t_grid, X, M

def normalize_window_median(x_raw, M):
    x = np.asarray(x_raw, dtype=float).copy()
    m = (np.asarray(M, dtype=np.uint8) > 0)

    if m.sum() < 10:
        out = np.zeros_like(x, dtype=np.float32)
        out[m] = np.nan_to_num(x[m], nan=0.0)
        return out.astype(np.float32)

    baseline = np.median(x[m])
    if not np.isfinite(baseline) or baseline == 0:
        baseline = 1.0

    x_norm = x / baseline
    if CENTER_X_AROUND_ZERO:
        x_norm = x_norm - 1.0

    x_norm[~m] = 0.0
    x_norm = np.nan_to_num(x_norm, nan=0.0, posinf=0.0, neginf=0.0)
    return x_norm.astype(np.float32)

# -----------------------------
# TRUTH: enumerate all transit centers across the star time span
# -----------------------------
def enumerate_transit_centers_for_star(lc, planets, t_min, t_max):
    truth = []
    if len(planets) == 0:
        return truth

    for p in planets:
        P = float(p["P_days"])
        if not (np.isfinite(P) and P > 0):
            continue
        t0_lc = float(bjd_to_lc_time(lc, p["t0_bjd"]))
        dur_eff = clamp_duration_days(P, p.get("dur_days_cat", np.nan))

        n0 = int(np.floor((t_min - t0_lc) / P))
        n1 = int(np.ceil((t_max - t0_lc) / P))

        for n in range(n0, n1 + 1):
            t_c = t0_lc + n * P
            if t_min <= t_c <= t_max:
                truth.append({
                    "pl_name": p["name"],
                    "P_days": float(P),
                    "t_c": float(t_c),
                    "dur_eff_days": float(dur_eff),
                })

    truth.sort(key=lambda r: r["t_c"])
    return truth

def truth_events_in_window(t0, t1, truth_list):
    out = []
    for ev in truth_list:
        if t0 <= ev["t_c"] <= t1:
            i_c = int(np.round((ev["t_c"] - t0) / DT_DAYS))
            half = int(np.ceil((0.5 * ev["dur_eff_days"]) / DT_DAYS))
            out.append({
                "pl_name": ev["pl_name"],
                "t_c": float(ev["t_c"]),
                "P_days": float(ev["P_days"]),
                "dur_eff_days": float(ev["dur_eff_days"]),
                "i_c": int(i_c),
                "i0": int(i_c - half),
                "i1": int(i_c + half),
            })
    return out

def center_heatmap(events):
    Y = np.zeros(T, dtype=np.float32)
    if len(events) == 0:
        return Y

    sigma = float(CENTER_SIGMA_CAD)
    rad = int(np.ceil(CENTER_CUTOFF_SIG * sigma))

    for ev in events:
        i_c = int(ev["i_c"])
        if not (0 <= i_c < T):
            continue
        lo = max(0, i_c - rad)
        hi = min(T - 1, i_c + rad)
        ii = np.arange(lo, hi + 1, dtype=float)
        bump = np.exp(-0.5 * ((ii - i_c) / sigma) ** 2).astype(np.float32)
        Y[lo:hi+1] = np.maximum(Y[lo:hi+1], bump)

    return Y

# -----------------------------
# FLARES (your proven detector)
# -----------------------------
def flare_flags_full_lc(
    t, f, cadence_days,
    W_DAYS=FLARE_W_DAYS,
    K_AMP=FLARE_K_AMP,
    K_RISE=FLARE_K_RISE,
    K_DECAY=FLARE_K_DECAY,
    MIN_LEN=FLARE_MIN_LEN,
    MAX_LEN_HOURS=FLARE_MAX_LEN_HRS,
    GAP_MULT=FLARE_GAP_MULT,
    RISE_LOOKBACK=FLARE_RISE_LOOKBACK
):
    t = np.asarray(t, float)
    f = np.asarray(f, float)

    W = max(7, int(round(W_DAYS / cadence_days)))
    if W % 2 == 0:
        W += 1

    baseline = pd.Series(f).rolling(window=W, center=True, min_periods=max(5, W // 3)).median().to_numpy()
    resid = f - baseline

    dt = np.diff(t)
    gap_ok = np.ones_like(t, dtype=bool)
    gap_ok[1:] = dt < (GAP_MULT * cadence_days)
    gap_ok[:-1] &= dt < (GAP_MULT * cadence_days)

    sigma_res = mad_sigma(resid[gap_ok])
    if not (np.isfinite(sigma_res) and sigma_res > 0):
        return np.zeros_like(t, dtype=bool)

    dr2 = np.full_like(resid, np.nan)
    dr2[2:] = resid[2:] - resid[:-2]
    sigma_dr = mad_sigma(dr2[gap_ok])
    if not (np.isfinite(sigma_dr) and sigma_dr > 0):
        return np.zeros_like(t, dtype=bool)

    amp_thr   = K_AMP   * sigma_res
    rise_thr  = K_RISE  * sigma_dr
    decay_thr = K_DECAY * sigma_res

    hot = gap_ok & np.isfinite(resid) & (resid > amp_thr)
    idx = np.where(hot)[0]

    flare_flag = np.zeros_like(t, dtype=bool)
    if idx.size == 0:
        return flare_flag

    MAX_LEN = int(round((MAX_LEN_HOURS / 24.0) / cadence_days))
    MAX_LEN = max(MAX_LEN, MIN_LEN)

    splits = np.where(np.diff(idx) > 1)[0]
    starts = np.r_[0, splits + 1]
    ends   = np.r_[splits, idx.size - 1]

    for a, b in zip(starts, ends):
        seg = idx[a:b+1]
        L = len(seg)
        if L < MIN_LEN or L > MAX_LEN:
            continue

        pk = int(seg[np.argmax(resid[seg])])
        if pk < 2:
            continue

        lo = max(2, pk - int(RISE_LOOKBACK))
        hi = pk + 1
        if hi <= lo:
            continue

        dr_slice = dr2[lo:hi]
        dr_slice = dr_slice[np.isfinite(dr_slice)]
        if dr_slice.size == 0:
            continue
        if not (np.max(dr_slice) > rise_thr):
            continue

        j2 = min(len(resid) - 1, pk + 4)
        post = resid[pk+1:j2+1]
        if post.size == 0 or not np.all(np.isfinite(post)):
            continue
        if not (np.nanmax(resid[pk] - post) > decay_thr):
            continue

        lo2 = max(0, seg[0] - 1)
        hi2 = min(len(resid), seg[-1] + 2)
        flare_flag[lo2:hi2] = True

    return flare_flag

def detect_flares_full_lc(lc):
    t = np.asarray(lc.time.value, dtype=float)
    f = np.asarray(lc.flux.value, dtype=float)
    good = np.isfinite(t) & np.isfinite(f)
    t, f = t[good], f[good]
    if t.size < 10:
        return t, np.zeros_like(t, dtype=bool)
    order = np.argsort(t)
    t, f = t[order], f[order]
    dts = np.diff(t)
    cadence_est = np.nanmedian(dts[np.isfinite(dts)]) if dts.size else DT_DAYS
    if not (np.isfinite(cadence_est) and cadence_est > 0):
        cadence_est = DT_DAYS
    flare_flag = flare_flags_full_lc(t, f, cadence_days=cadence_est)
    return t, flare_flag

def map_flags_to_grid_nn(t_full, flag_full, t_grid):
    out = np.zeros(T, dtype=np.float32)
    t_full = np.asarray(t_full, float)
    flag_full = np.asarray(flag_full, bool)
    if t_full.size == 0:
        return out

    order = np.argsort(t_full)
    ts = t_full[order]
    fs = flag_full[order]

    idx = np.searchsorted(ts, t_grid, side="left")
    left = np.clip(idx - 1, 0, ts.size - 1)
    right = np.clip(idx, 0, ts.size - 1)

    d_left = np.abs(t_grid - ts[left])
    d_right = np.abs(t_grid - ts[right])

    choose_right = d_right < d_left
    nearest = np.where(choose_right, right, left)
    d_near = np.minimum(d_left, d_right)

    ok = d_near < NN_TOL
    out[ok] = fs[nearest[ok]].astype(np.float32)
    return out

