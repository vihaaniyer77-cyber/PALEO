m = m[m["status"].isin(["ok", "cached"])].copy()

# Read real starlist
stars = pd.read_csv(STARLIST_PATH, on_bad_lines="skip")
if "kepid" not in stars.columns:
    raise KeyError("STARLIST must contain 'kepid' column.")
if "hostname" not in stars.columns:
