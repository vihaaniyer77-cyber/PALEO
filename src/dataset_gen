# WINDOWING (your proven version)
# -----------------------------
def is_valid_window(t, f):
    good = np.isfinite(t) & np.isfinite(f)
    t_good = t[good]
    if len(t_good) < 2:
        return False
    if np.max(np.diff(np.sort(t_good))) > hours_to_days(MAX_GAP_HOURS):
        return False
    expected = int(round(WINDOW_DAYS * 24 * 60 / CADENCE_MIN))
    min_points = int(np.ceil((1.0 - MAX_MISSING_FRAC) * expected))
    return len(t_good) >= min_points

def window_lc(lc):
    t = np.asarray(lc.time.value, float)
    f = np.asarray(lc.flux.value, float)
    good = np.isfinite(t) & np.isfinite(f)
    t, f = t[good], f[good]
    if t.size < 2:
        return []

    order = np.argsort(t)
    t, f = t[order], f[order]

    win  = WINDOW_DAYS
    step = WINDOW_DAYS * (1 - OVERLAP_FRAC)

    start0 = np.floor(t.min() / DT_DAYS) * DT_DAYS
    windows = []
    start = start0
    tmax = t.max()

    while start + win <= tmax:
        end = start + win
        i0 = np.searchsorted(t, start, side="left")
        i1 = np.searchsorted(t, end,   side="left")
        if i1 - i0 > 0:
            tw, fw = t[i0:i1], f[i0:i1]
            if is_valid_window(tw, fw):
                windows.append((tw, fw, float(start), float(end)))
        start += step

    return windows

# -----------------------------
# TIME SYSTEM (same heuristic you used)
