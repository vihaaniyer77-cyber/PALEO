def _looks_like_dataset_dir(d):
    return (
        os.path.isdir(d)
        and os.path.exists(os.path.join(d, "X.npy"))
        and os.path.exists(os.path.join(d, "Y.npy"))
        and os.path.exists(os.path.join(d, "M.npy"))
        and os.path.exists(os.path.join(d, "splits.json"))
    )

def ensure_dataset_present():
    if _looks_like_dataset_dir(PREFERRED_DIR):
        return PREFERRED_DIR

    if os.path.exists(DATASET_ZIP):
        print(f"[INFO] {PREFERRED_DIR}/ not found. Unzipping {DATASET_ZIP} ...", flush=True)
        with zipfile.ZipFile(DATASET_ZIP, "r") as z:
            z.extractall(".")
        print("[INFO] Unzip complete.", flush=True)

    candidates = ["datasets/dataset_v1", "dataset_v1", "datasets", "."]
    for c in candidates:
        if _looks_like_dataset_dir(c):
            print("[INFO] Using DATASET_DIR:", c, flush=True)
            return c

    for root, dirs, files in os.walk(".", topdown=True):
        rel = os.path.relpath(root, ".")
        if rel.count(os.sep) > 3:
            dirs[:] = []
            continue
        if _looks_like_dataset_dir(root):
            print("[INFO] Using DATASET_DIR:", root, flush=True)
            return root

    raise FileNotFoundError("Unzipped, but couldn't locate dataset folder with X/Y/M/splits.json.")

