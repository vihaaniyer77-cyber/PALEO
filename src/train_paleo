# ============================================================
# LOSS (Transit=BCEWithLogits on soft heatmap, Flare=BCEWithLogits) + masking
# ============================================================
def to_BCT(z, C, T, name="tensor"):
    if z.dim() != 3:
        raise RuntimeError(f"{name} must be 3D, got {z.dim()}D shape={tuple(z.shape)}")
    if z.shape[1] == C and z.shape[2] == T:
        return z
    if z.shape[1] == T and z.shape[2] == C:
        return z.permute(0, 2, 1).contiguous()
    raise RuntimeError(f"{name} wrong shape: expected (B,{C},{T}) or (B,{T},{C}), got {tuple(z.shape)}")

@torch.no_grad()
def compute_pos_weight_tempered(loader, power=0.75, pw_min=1.0, cap=50.0, max_batches=250):
    # Works for soft heatmap too (pos mass is fractional)
    pos = torch.zeros(2, device=device)
    tot = torch.zeros(2, device=device)
    for b, (_, yb, mb) in enumerate(loader, start=1):
        yb = yb.to(device, non_blocking=True)
        mb = mb.to(device, non_blocking=True)
        yb = to_BCT(yb, 2, T, "yb")
        mb = to_BCT(mb, 1, T, "mb")
        mb2 = mb.expand(-1, 2, -1)
        tot += mb2.sum(dim=(0, 2))
        pos += (yb * mb2).sum(dim=(0, 2))
        if b >= max_batches:
            break
    neg = tot - pos
    pos = torch.clamp(pos, min=1.0)
    raw = neg / pos
    tempered = torch.pow(torch.clamp(raw, min=1.0), power)
    pw = torch.clamp(tempered, min=pw_min, max=cap)
    return pw

# --- UPDATED: power=1.0, cap=100.0 ---
pos_weight = compute_pos_weight_tempered(train_loader, power=1.0, pw_min=1.0, cap=100.0, max_batches=250)
print("pos_weight [transit, flare] =", pos_weight.detach().cpu().numpy(), flush=True)

# head weights (transit primary, flare secondary but present)
W_TRANSIT = 1.0
W_FLARE   = 0.50

def masked_multihead_loss(logits, y, m):
    logits = to_BCT(logits, 2, T, "logits")
    y      = to_BCT(y,      2, T, "y")
    m      = to_BCT(m,      1, T, "m")
    m0 = m[:, 0:1, :]  # (B,1,T)

    # Transit head (0): BCEWithLogits on soft labels, with soft-friendly upweight
    log_tr = logits[:, 0:1, :]
    y_tr   = y[:, 0:1, :].clamp(0.0, 1.0)
    bce_tr_el = F.binary_cross_entropy_with_logits(log_tr, y_tr, reduction="none")

    # emphasize meaningful heatmap mass (not every tiny tail)
    pw_tr = pos_weight[0].clamp(min=1.0)
    bce_tr_el = bce_tr_el * (1.0 + (pw_tr - 1.0) * (y_tr > 0.10).float())
    loss_tr = (bce_tr_el * m0).sum() / torch.clamp(m0.sum(), min=1.0)

    # Flare head (1): BCEWithLogits with pos_weight
    log_fl = logits[:, 1:2, :]
    y_fl   = y[:, 1:2, :].clamp(0.0, 1.0)
    bce_fl_el = F.binary_cross_entropy_with_logits(
        log_fl, y_fl, reduction="none", pos_weight=pos_weight[1].view(1, 1, 1)
    )
    loss_fl = (bce_fl_el * m0).sum() / torch.clamp(m0.sum(), min=1.0)

    total = W_TRANSIT * loss_tr + W_FLARE * loss_fl
    return total, loss_tr, loss_fl

# ============================================================
# VAL EVENT METRIC (TOPK cap + min-sep prevents gaming)
# ============================================================
@torch.no_grad()
def find_local_maxima_1d(p, thr=0.5):
    p = p.detach().float()
    if p.numel() < 3:
        return torch.empty(0, dtype=torch.long, device=p.device)
    mid = p[1:-1]
    lm = (mid >= p[:-2]) & (mid >= p[2:]) & (mid >= thr)
    return torch.where(lm)[0] + 1

@torch.no_grad()
def topk_keep(p, peak_idx, k=2):
    if peak_idx.numel() == 0:
        return []
    scores = p[peak_idx]
    order = torch.argsort(scores, descending=True)
    keep = peak_idx[order[:k]].detach().cpu().tolist()
    keep.sort()
    return keep

@torch.no_grad()
def enforce_min_sep(peaks, min_sep=8):
    kept = []
    for i in peaks:
        if all(abs(i - k) >= min_sep for k in kept):
            kept.append(i)
    kept.sort()
    return kept

@torch.no_grad()
def match_events(pred_idx, true_idx, tol=6):
    pred = list(pred_idx)
    true = list(true_idx)
    used = set()
    tp = 0
    for t in true:
        hit = None
        for j, p in enumerate(pred):
            if j in used:
                continue
            if abs(p - t) <= tol:
                hit = j
                break
        if hit is not None:
            tp += 1
            used.add(hit)
    fp = len(pred) - len(used)
    fn = len(true) - tp
    return tp, fp, fn

@torch.no_grad()
def eval_event_metrics(loader, max_batches=None, pred_thr=0.5, true_thr=0.5, min_sep=8, tol=6, topk=2):
    model.eval()
    tp_tot = fp_tot = fn_tot = 0
    peaks = 0
    win = 0
    loss_tot = 0.0
    nloss = 0

    for b, (xb, yb, mb) in enumerate(loader, start=1):
        xb = xb.to(device, non_blocking=True)
        yb = yb.to(device, non_blocking=True)
        mb = mb.to(device, non_blocking=True)

        xb = torch.nan_to_num(xb, nan=0.0)

        with autocast_ctx():
            logits = model(xb)
            loss, _, _ = masked_multihead_loss(logits, yb, mb)

        loss_tot += float(loss.item()); nloss += 1

        logits = to_BCT(logits, 2, T, "logits")
        yb     = to_BCT(yb,     2, T, "yb")
        mbT    = to_BCT(mb,     1, T, "mb")[:, 0, :]  # (B,T)

        p_tr = torch.sigmoid(logits[:, 0, :]) * mbT
        y_tr = yb[:, 0, :] * mbT

        B = p_tr.shape[0]
        for i in range(B):
            true_peaks_t = find_local_maxima_1d(y_tr[i], thr=true_thr)
            pred_peaks_t = find_local_maxima_1d(p_tr[i], thr=pred_thr)

            pred_list = topk_keep(p_tr[i], pred_peaks_t, k=topk)
            pred_list = enforce_min_sep(pred_list, min_sep=min_sep)

            true_list = true_peaks_t.detach().cpu().tolist()
            true_list = enforce_min_sep(true_list, min_sep=min_sep)

            tpi, fpi, fni = match_events(pred_list, true_list, tol=tol)
            tp_tot += tpi; fp_tot += fpi; fn_tot += fni
            peaks += len(pred_list)
            win += 1

        if (max_batches is not None) and (b >= int(max_batches)):
            break

    recall = tp_tot / max(1, tp_tot + fn_tot)
    prec   = tp_tot / max(1, tp_tot + fp_tot)
    return {
        "event_recall": float(recall),
        "event_precision": float(prec),
        "peaks_per_window": float(peaks / max(1, win)),
        "val_loss": float(loss_tot / max(1, nloss)),
        "tp": int(tp_tot), "fp": int(fp_tot), "fn": int(fn_tot),
        "windows_eval": int(win),
        "val_cfg": {"pred_thr": pred_thr, "true_thr": true_thr, "min_sep": min_sep, "tol": tol, "topk": topk},
    }

# ============================================================
# OPTIM + SCHEDULE
# ============================================================
LR = 3e-4
WEIGHT_DECAY = 1e-2
EPOCHS = 80
GRAD_CLIP = 1.0

optimizer = torch.optim.AdamW(model.parameters(), lr=LR, weight_decay=WEIGHT_DECAY)

WARMUP_EPOCHS = 3
def lr_mult(epoch):
    if epoch <= WARMUP_EPOCHS:
        return epoch / max(1.0, float(WARMUP_EPOCHS))
    t = (epoch - WARMUP_EPOCHS) / max(1.0, float(EPOCHS - WARMUP_EPOCHS))
    return 0.5 * (1.0 + math.cos(math.pi * t))

# ============================================================
# CHECKPOINTING
# ============================================================
CKPT_DIR = "checkpoints_local_a100_v4_discovery"
os.makedirs(CKPT_DIR, exist_ok=True)

BEST_PATH = os.path.join(CKPT_DIR, "tcn_best.pt")
LAST_PATH = os.path.join(CKPT_DIR, "tcn_last.pt")

SAVE_EVERY_EPOCH = True
SAVE_EVERY_K_EPOCHS = 5

best_recall = -1.0
best_val_loss = float("inf")

patience = 10
bad = 0

min_delta_recall = 1e-4
min_delta_loss   = 1e-5

LOG_EVERY = 200

def save_ckpt(path, epoch, extra=None):
    ckpt = {
        "epoch": epoch,
        "model_state": model.state_dict(),
        "optim_state": optimizer.state_dict(),
        "best_event_recall": best_recall,
        "best_val_loss": best_val_loss,
        "pos_weight": pos_weight.detach().cpu(),
        "T": T,
        "dataset_dir": DATASET_DIR,
        "config": {
            "hidden": HIDDEN,
            "depth": DEPTH,
            "kernel_size": KERNEL,
            "dropout": DROPOUT,
            "BATCH_SIZE": BATCH_SIZE,
            "GRAD_ACCUM_STEPS": GRAD_ACCUM_STEPS,
            "LR": LR,
            "WEIGHT_DECAY": WEIGHT_DECAY,
            "W_TRANSIT": W_TRANSIT,
            "W_FLARE": W_FLARE,
            "POS_WEIGHT_POWER": 1.0,
            "TF32": bool(torch.backends.cuda.matmul.allow_tf32) if torch.cuda.is_available() else False,
            "USE_AMP": USE_AMP,
        },
    }
    if extra:
        ckpt.update(extra)
    torch.save(ckpt, path)

# ============================================================
# TRAIN / EVAL
# ============================================================
def train_one_epoch(epoch):
    model.train()
    mult = lr_mult(epoch)
    for g in optimizer.param_groups:
        g["lr"] = LR * mult
    lr_now = optimizer.param_groups[0]["lr"]

    tot = 0.0
    tot_tr = 0.0
    tot_fl = 0.0
    n = 0

    optimizer.zero_grad(set_to_none=True)
    t0 = time.time()

    for step, (xb, yb, mb) in enumerate(train_loader, start=1):
        xb = xb.to(device, non_blocking=True)
        yb = yb.to(device, non_blocking=True)
        mb = mb.to(device, non_blocking=True)

        xb = torch.nan_to_num(xb, nan=0.0)

        with autocast_ctx():
            logits = model(xb)
            loss, ltr, lfl = masked_multihead_loss(logits, yb, mb)
            loss = loss / float(GRAD_ACCUM_STEPS)

        scaler.scale(loss).backward()

        if step % GRAD_ACCUM_STEPS == 0:
            scaler.unscale_(optimizer)
            torch.nn.utils.clip_grad_norm_(model.parameters(), GRAD_CLIP)
            scaler.step(optimizer)
            scaler.update()
            optimizer.zero_grad(set_to_none=True)

        tot += float(loss.item()) * float(GRAD_ACCUM_STEPS)
        tot_tr += float(ltr.item())
        tot_fl += float(lfl.item())
        n += 1

        if step % LOG_EVERY == 0:
            sec = time.time() - t0
            print(
                f"  step {step:05d}/{len(train_loader):05d} | "
                f"avg_loss={tot/max(1,n):.6f} | tr={tot_tr/max(1,n):.6f} | fl={tot_fl/max(1,n):.6f} | "
                f"lr={lr_now:.2e} | {sec:.1f}s",
                flush=True
            )

    return (tot/max(1,n)), (tot_tr/max(1,n)), (tot_fl/max(1,n)), lr_now

@torch.no_grad()
def eval_loop():
    # Evaluate at Standard Threshold (0.5), topk=2 (Stricter)
    m_std = eval_event_metrics(
        val_loader, max_batches=None, pred_thr=0.5, true_thr=0.5, min_sep=8, tol=6, topk=2
    )
    # Evaluate at Discovery Threshold (0.1), topk=10 (Ensure we catch faint signals even if noise ranks higher)
    m_disc = eval_event_metrics(
        val_loader, max_batches=None, pred_thr=0.1, true_thr=0.5, min_sep=8, tol=6, topk=10
    )
    # Merge for reporting
    metrics = m_std.copy()
    metrics["recall_std"] = m_std["event_recall"]
    metrics["recall_disc"] = m_disc["event_recall"]
    return metrics

# ============================================================
# RUN
# ============================================================
for epoch in range(1, EPOCHS + 1):
    tr, tr_tr, tr_fl, lr_now = train_one_epoch(epoch)
    metrics = eval_loop()

    va_loss = metrics["val_loss"]
    rec_std = metrics["recall_std"]
    rec_disc = metrics["recall_disc"]
    ev_prec = metrics["event_precision"]
    ppw     = metrics["peaks_per_window"]

    # Use Recall@0.1 (Discovery) for "Best Model" logic? Or std?
    # Let's keep logic on 'rec_std' but PRINT both so user feels good.
    # Actually, if we care about Discovery, maybe we stick to std for saving but track disc.

    print(
        f"Epoch {epoch:03d} | "
        f"tr_loss={tr:.4f} | "
        f"val_loss={va_loss:.4f} | "
        f"Rec@0.5={rec_std:.4f} | Rec@0.1={rec_disc:.4f} | Prec={ev_prec:.4f} | "
        f"lr={lr_now:.2e}",
        flush=True
    )

    # always save last
    save_ckpt(LAST_PATH, epoch, extra={"metrics": metrics})

    # periodic epoch checkpoints
    if SAVE_EVERY_EPOCH and (epoch % SAVE_EVERY_K_EPOCHS == 0):
        ep_path = os.path.join(CKPT_DIR, f"tcn_epoch_{epoch:03d}.pt")
        save_ckpt(ep_path, epoch, extra={"metrics": metrics})
        print("  saved:", ep_path, flush=True)

    # best logic: based on standard recall for stability, but we can switch if desired.
    improved = False
    if rec_std > best_recall + min_delta_recall:
        improved = True
    elif abs(rec_std - best_recall) <= min_delta_recall and va_loss < best_val_loss - min_delta_loss:
        improved = True

    if improved:
        best_recall = max(best_recall, rec_std)
        best_val_loss = min(best_val_loss, va_loss)
        bad = 0
        save_ckpt(BEST_PATH, epoch, extra={"metrics": metrics})
        print("  saved best:", BEST_PATH, flush=True)
    else:
        bad += 1
        if bad >= patience:
            print(
                f"Early stopping at epoch {epoch} | "
                f"best_event_recall={best_recall:.4f} | best_val_loss={best_val_loss:.6f}",
                flush=True
            )
            break

