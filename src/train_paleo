class WindowDataset(Dataset):
    def __init__(self, X, Y, M, indices):
        self.X = X
        self.Y = Y
        self.M = M
        self.idx = np.asarray(indices, dtype=np.int64)

    def __len__(self):
        return self.idx.size

    def __getitem__(self, i):
        j = int(self.idx[i])
        x = torch.from_numpy(np.asarray(self.X[j])).float()  # (T,1)
        y = torch.from_numpy(np.asarray(self.Y[j])).float()  # (T,2)
        m = torch.from_numpy(np.asarray(self.M[j])).float()  # (T,1)
        x = x.permute(1, 0).contiguous()  # (1,T)
        y = y.permute(1, 0).contiguous()  # (2,T)
        m = m.permute(1, 0).contiguous()  # (1,T)
        return x, y, m

